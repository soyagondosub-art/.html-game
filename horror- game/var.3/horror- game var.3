                gridZ: gridZ,
                type: type,
                label: label,
                mesh: mesh,
                radius: 1.4
            });
        }

        // 徘徊用のランダムな空き座標（床）を取得する関数
        function getRandomPatrolNode() {
            let emptyNodes = [];
            for (let r = 1; r < mapData.length - 1; r++) {
                for (let c = 1; c < mapData[r].length - 1; c++) {
                    if (mapData[r][c] === 0) {
                        emptyNodes.push({ x: c, z: r });
                    }
                }
            }
            if (emptyNodes.length > 0) {
                let node = emptyNodes[Math.floor(Math.random() * emptyNodes.length)];
                return { x: node.x * SCALE, z: node.z * SCALE };
            }
            return { x: config.diaryGrid.x * SCALE, z: config.diaryGrid.z * SCALE };
        }

