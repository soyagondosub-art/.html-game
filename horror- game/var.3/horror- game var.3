        function buildMazeObjects() {
            mazeWalls.forEach(w => scene.remove(w)); mazeWalls = [];
            hidingPlacesInScene.forEach(h => scene.remove(h.mesh)); hidingPlacesInScene = [];

            let wallMap = new Map();
            for (let r = 0; r < mapData.length; r++) {
                for (let c = 0; c < mapData[r].length; c++) {
                    if (mapData[r][c] === 1) {
                        const wMesh = new THREE.Mesh(wallGeo, wallMat);
                        wMesh.position.set(c * SCALE, 3.5 / 2, r * SCALE);
                        wMesh.castShadow = true; wMesh.receiveShadow = true;
                        scene.add(wMesh); mazeWalls.push(wMesh);
                        wallMap.set(`${c}_${r}`, true);
                    }
                }
            }

            let hidingCandidates = [];
            for (let r = 1; r < mapData.length - 1; r++) {
                for (let c = 1; c < mapData[r].length - 1; c++) {
                    if (mapData[r][c] === 0 && 
                        !(c === config.startGrid.x && r === config.startGrid.z) && 
                        !(c === config.diaryGrid.x && r === config.diaryGrid.z)) {
                        hidingCandidates.push({x: c, z: r});
                    }
                }
            }

            let types = ['shelf', 'closet', 'bed', 'shelf'];
            let typeLabels = { 'shelf': '棚', 'closet': 'クローゼット', 'bed': 'ベッドの下' };
            
            let indices = [
                Math.floor(hidingCandidates.length * 0.2),
                Math.floor(hidingCandidates.length * 0.4),
                Math.floor(hidingCandidates.length * 0.6),
                Math.floor(hidingCandidates.length * 0.8)
            ];

            indices.forEach((idx, i) => {
                if (idx < hidingCandidates.length) {
                    let cand = hidingCandidates[idx];
                    let type = types[i % 3];
                    createHidingMesh(cand.x, cand.z, type, typeLabels[type]);
                }
            });

            diaryMesh.position.set(config.diaryGrid.x * SCALE, 0.3, config.diaryGrid.z * SCALE);
        }

