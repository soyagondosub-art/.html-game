                geom = new THREE.BoxGeometry(1.6, 0.8, 1.2);
                mat = new THREE.MeshStandardMaterial({ color: 0x444444, roughness: 0.9 });
            }

            const mesh = new THREE.Mesh(geom, mat);
            mesh.position.set(gridX * SCALE, geom.parameters.height / 2, gridZ * SCALE);
            scene.add(mesh);

            hidingPlacesInScene.push({
