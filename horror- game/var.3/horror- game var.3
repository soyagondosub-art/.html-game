        }

        function checkCollision(nx, nz) {
            let buffer = 0.32;
            let checkPoints = [
                {x: nx - buffer, z: nz - buffer}, {x: nx + buffer, z: nz - buffer},
                {x: nx - buffer, z: nz + buffer}, {x: nx + buffer, z: nz + buffer}
            ];
            for (let p of checkPoints) {
                let gridX = Math.floor((p.x + SCALE/2) / SCALE); let gridZ = Math.floor((p.z + SCALE/2) / SCALE);
                if (gridZ < 0 || gridZ >= mapData.length || gridX < 0 || gridX >= mapData[0].length) return true;
                if (mapData[gridZ][gridX] === 1) return true;
            }
            return false;
        }

        function checkHidingInteraction() {
            if (!gameActive || isDead) return;

            if (isHiding) {
                exitCurrentHidingPlace();
                return;
            }

            let closePlace = null;
            for (let hp of hidingPlacesInScene) {
                let dx = playerPos.x - hp.gridX * SCALE;
                let dz = playerPos.z - hp.gridZ * SCALE;
                let dist = Math.sqrt(dx*dx + dz*dz);
                if (dist < hp.radius) {
                    closePlace = hp;
                    break;
                }
            }

            if (closePlace) {
                enterHidingPlace(closePlace);
            }
        }

        function enterHidingPlace(place) {
            isHiding = true;
            activeHidingPlace = place;
            playSwitchSound();

            // クロセが目視追跡中だった場合は、見つかっている状態になる
            if (isChaserLookingAtPlayer) {
                hidingSpotted = true; 
            } else {
                hidingSpotted = false;
                isChaserChasing = false; // 完全に見失う
            }

            playerPos.x = place.gridX * SCALE;
            playerPos.z = place.gridZ * SCALE;
            
            document.getElementById('hiding-prompt').innerText = `【隠れ中】${place.label}に身を潜めている... (Eキーで出る)`;
        }

        function exitCurrentHidingPlace() {
            if (!isHiding || !activeHidingPlace) return;

            playSwitchSound();
            
            playerPos.x += Math.sin(-yaw) * 0.5;
            playerPos.z -= Math.cos(-yaw) * 0.5;

            isHiding = false;
            activeHidingPlace = null;
            hidingSpotted = false;
            document.getElementById('hiding-prompt').style.display = "none";
        }

        function updatePlayerMovement(time) {
            if (!isHiding) {
                let closePlace = null;
                for (let hp of hidingPlacesInScene) {
                    let dx = playerPos.x - hp.gridX * SCALE;
                    let dz = playerPos.z - hp.gridZ * SCALE;
                    let dist = Math.sqrt(dx*dx + dz*dz);
                    if (dist < hp.radius) {
                        closePlace = hp;
                        break;
                    }
                }
                if (closePlace) {
                    const prompt = document.getElementById('hiding-prompt');
                    prompt.innerText = `[Eキー] を押して ${closePlace.label} に隠れる`;
                    prompt.style.display = "block";
                } else {
                    document.getElementById('hiding-prompt').style.display = "none";
                }
            } else {
                document.getElementById('hiding-prompt').block;
                camera.position.set(playerPos.x, playerPos.y, playerPos.z);
                playerLight.position.set(playerPos.x, playerPos.y, playerPos.z);
                return;
            }

            if (keys['shift'] && stamina > 5 && !staminaExhausted && (keys['w'] || keys['s'] || keys['a'] || keys['d'])) {
                isSprinting = true; stamina = Math.max(0, stamina - 0.55); if (stamina <= 0) staminaExhausted = true;
            } else {
                isSprinting = false; stamina = Math.min(100, stamina + 0.25); if (stamina >= 25) staminaExhausted = false;
            }
            document.getElementById('stamina-bar').style.width = `${stamina}%`;
            document.getElementById('stamina-bar').style.background = staminaExhausted ? '#ff3333' : (isSprinting ? '#ffcc00' : '#00ffaa');

            let moveSpeed = isSprinting ? SPRINT_PLAYER_SPEED : BASE_PLAYER_SPEED;
            let forward = new THREE.Vector3(0, 0, -1).applyAxisAngle(new THREE.Vector3(0, 1, 0), yaw);
            let right = new THREE.Vector3(1, 0, 0).applyAxisAngle(new THREE.Vector3(0, 1, 0), yaw);
            let moveVec = new THREE.Vector3();

            if (keys['w']) moveVec.add(forward); if (keys['s']) moveVec.sub(forward);
            if (keys['d']) moveVec.add(right); if (keys['a']) moveVec.sub(right);
            if (moveVec.lengthSq() > 0) {
                moveVec.normalize().multiplyScalar(moveSpeed);
                let nextX = playerPos.x + moveVec.x; let nextZ = playerPos.z + moveVec.z;
                if (!checkCollision(nextX, playerPos.z)) playerPos.x = nextX;
                if (!checkCollision(playerPos.x, nextZ)) playerPos.z = nextZ;
                if (time >= nextPlayerFootTime) { playPlayerFootstep(isSprinting); nextPlayerFootTime = time + (isSprinting ? 0.18 : 0.32); }
                
                // 走っている足音は少し遠くからでもクロセを引き寄せる
                if (isSprinting && !isHiding) {
                    let pdx = playerPos.x - chaserPos.x; let pdz = playerPos.z - chaserPos.z;
                    if (Math.sqrt(pdx*pdx + pdz*pdz) < SCALE * 5.0) {
                        isChaserChasing = true; 
                    }
                }
            }

            if (keys[' '] && !isJumping) { isJumping = true; velocityY = JUMP_FORCE; }
            if (isJumping) { playerPos.y += velocityY; velocityY += GRAVITY; if (playerPos.y <= PLAYER_HEIGHT) { playerPos.y = PLAYER_HEIGHT; isJumping = false; velocityY = 0; } }

            camera.position.set(playerPos.x, playerPos.y, playerPos.z);
            playerLight.position.set(playerPos.x, playerPos.y, playerPos.z);
        }

        // --- 改良版：クロセのAIロジック ---
        function updateChaserAI(time) {
            let dx = playerPos.x - chaserPos.x; let dz = playerPos.z - chaserPos.z;
            let dist = Math.sqrt(dx*dx + dz*dz);

            // 1. 視線（障害物）チェック
            let isSighted = false;
            if (!isHiding && dist < SCALE * 6.5) {
                let segments = 10; let clear = true;
                for (let i = 1; i < segments; i++) {
                    let tx = chaserPos.x + dx * (i / segments); let tz = chaserPos.z + dz * (i / segments);
                    let gx = Math.floor((tx + SCALE/2) / SCALE); let gz = Math.floor((tz + SCALE/2) / SCALE);
                    if (gz >= 0 && gz < mapData.length && gx >= 0 && gx < mapData[0].length) { 
                        if (mapData[gz][gx] === 1) { clear = false; break; } 
                    }
                }
                if (clear) isSighted = true;
            }
            isChaserLookingAtPlayer = isSighted;

            // 2. 状態による分岐
            if (isHiding && activeHidingPlace) {
                // 【隠れている場合】
                if (hidingSpotted) {
                    // 目前で隠れた場合はバレて襲ってくる
                    let targetX = activeHidingPlace.gridX * SCALE;
                    let targetZ = activeHidingPlace.gridZ * SCALE;
                    let tdx = targetX - chaserPos.x; let tdz = targetZ - chaserPos.z;
                    let tdist = Math.sqrt(tdx*tdx + tdz*tdz);
                    if (tdist > 0.1) {
                        chaserPos.x += (tdx / tdist) * chaserSpeed * 1.5; chaserPos.z += (tdz / tdist) * chaserSpeed * 1.5;
                    }
                    if (tdist < 0.4) { triggerJumpscare(); return; }
                } else {
                    // バレずに隠れられたら、やり過ごせる（付近を通り過ぎて別のランダムな場所へ向かう）
                    let tdx = chaserTargetNode.x - chaserPos.x; let tdz = chaserTargetNode.z - chaserPos.z;
                    let tdist = Math.sqrt(tdx*tdx + tdz*tdz);
                    if (tdist < 0.3) { chaserTargetNode = getRandomPatrolNode(); }
                    else {
                        chaserPos.x += (tdx / tdist) * chaserSpeed * 0.85; chaserPos.z += (tdz / tdist) * chaserSpeed * 0.85;
                    }
                }
            } 
            else if (isSighted || isChaserChasing) {
                // 【追跡モード：近くにいる・見えている・足音で気づかれた】
                isChaserChasing = true; 
                chaserPos.x += (dx / dist) * chaserSpeed * 1.5; chaserPos.z += (dz / dist) * chaserSpeed * 1.5;
                
                if (isSighted && dist < 4.0 && Math.random() < 0.006) {
                    let speech = document.getElementById('chaser-speech-overlay');
                    speech.innerText = horrorVoices[Math.floor(Math.random() * horrorVoices.length)];
                    speech.style.display = 'block'; setTimeout(() => { speech.style.display = 'none'; }, 1200);
                }
                
                // 距離をかなり離されると見失う
                if (dist > SCALE * 7.5) { isChaserChasing = false; chaserTargetNode = getRandomPatrolNode(); }
            } 
            else {
                // 【通常徘徊モード：病院内をさまよう】
                let tdx = chaserTargetNode.x - chaserPos.x; let tdz = chaserTargetNode.z - chaserPos.z;
                let tdist = Math.sqrt(tdx*tdx + tdz*tdz);
                
                if (tdist < 0.4) {
                    chaserTargetNode = getRandomPatrolNode(); // 目的地に着いたら次の場所へ
                } else {
                    chaserPos.x += (tdx / tdist) * chaserSpeed * 0.9; chaserPos.z += (tdz / tdist) * chaserSpeed * 0.9;
                }

                // さまよっている最中、突如近くをプレイヤーが通りかかったら補足
                if (dist < SCALE * 3.5) { isChaserChasing = true; }
            }

            chaserMesh.position.set(chaserPos.x, 1.1, chaserPos.z);
            chaserMesh.lookAt(camera.position.x, 1.1, camera.position.z);

            let alertUi = document.getElementById('yusei-alert');
            if (isChaserChasing && dist < SCALE * 4.0) { alertUi.style.display = 'block'; } else { alertUi.style.display = 'none'; }

            if (time >= nextBgmStepTime) { playDynamicBgmStep(dist, isSighted); let interval = 0.45 - (Math.max(0, Math.min(1.0, 1.0 - (dist / (SCALE * 6.5)))) * 0.32); nextBgmStepTime = time + interval; }
            if (time >= nextHeartbeatTime) { let severity = Math.max(0, Math.min(1.0, 1.0 - (dist / (SCALE * 5.0)))); if (severity > 0.1) { playHeartbeat(severity); } nextHeartbeatTime = time + (1.0 - severity * 0.75); }
            if (time >= nextChaserFootTime) { let vol = Math.max(0, Math.min(1.0, 1.0 - (dist / (SCALE * 6.0)))); if (vol > 0.05 && !isBlackout) { playChaserFootstep(vol); } nextChaserFootTime = time + 0.28; }

            if (dist < 0.65 && !isDead && !isHiding) {
                triggerJumpscare();
            }
        }

        function triggerJumpscare() {
            isDead = true; gameActive = false;
            document.exitPointerLock();
            playJumpscareScream();
            document.getElementById('jumpscare-overlay').style.display = 'flex';
            setTimeout(() => {
                document.getElementById('jumpscare-overlay').style.display = 'none';
                document.getElementById('screen-overlay').style.display = 'flex';
                document.getElementById('msg').innerHTML = `<span style="color:#ff0000;font-size:32px;text-shadow:0 0 10px #ff0000;">【精神崩壊：GAME OVER】</span><br><br>廃病院の闇に潜む「くろせ」の毒牙にかかり、あなたの意識は永遠に消失した…`;
                document.getElementById('action-btn').innerText = "もう一度潜入する";
            }, 2500);
        }

        function checkItemCollisions() {
            if (isHiding) return; 

            if (!hasDiary) {
                let dx = playerPos.x - config.diaryGrid.x * SCALE; let dz = playerPos.z - config.diaryGrid.z * SCALE;
                if (Math.sqrt(dx*dx + dz*dz) < 0.8) {
                    hasDiary = true; diaryMesh.visible = false; gameActive = false;
                    document.exitPointerLock();
                    document.getElementById('diary-content').innerText = diaryTexts[currentFloor];
                    document.getElementById('diary-overlay').style.display = 'flex';
                }
            } else {
                let dx = playerPos.x - config.startGrid.x * SCALE; let dz = playerPos.z - config.startGrid.z * SCALE;
                if (Math.sqrt(dx*dx + dz*dz) < 0.8) {
                    gameActive = false; document.exitPointerLock();
                    if (currentFloor < 3) {
                        document.getElementById('screen-overlay').style.display = 'flex';
                        document.getElementById('msg').innerHTML = `<span style="color:#00ffaa;font-size:32px;">【フロア走破成功】</span><br><br>田中チー牛１１歳の日記の回収に成功した。しかし、更なる怨念が上層から響き渡る…`;
                        document.getElementById('action-btn').innerText = `${currentFloor + 1}階へ進む`;
                    } else {
                        document.getElementById('screen-overlay').style.display = 'flex';
                        document.getElementById('msg').innerHTML = `<span style="color:#ffff00;font-size:36px;text-shadow:0 0 20px #ffff00;">【完全大脱出成功】</span><br><br>おめでとう！全ての謎と恐怖を乗り越え、あなたはこの地獄の廃病院から生きて帰還した！`;
                        document.getElementById('action-btn').innerText = "最初から遊ぶ";
                    }
                }
            }
        }

        function updateEnvironmentLights(time, deltaTime) {
            blackoutCycleTimer += deltaTime;
            minimapGlobalTimer += deltaTime; 

            if (blackoutCycleTimer >= 30.0) { blackoutCycleTimer = 0; isBlackout = false; hasPlayedWarningSound = false; document.getElementById('game-body').classList.remove('blackout-glitch'); }
            else if (blackoutCycleTimer >= 28.0) {
                if (!isBlackout) { isBlackout = true; playSparkSound(); document.getElementById('game-body').classList.add('blackout-glitch'); }
            } else if (blackoutCycleTimer >= 25.0) {
                if (!hasPlayedWarningSound) { hasPlayedWarningSound = true; playSparkSound(); }
                if (Math.random() < 0.18) { flashlight.intensity = Math.random() * 4; } else { flashlight.intensity = 25; }
            } else {
                flashlight.intensity = isFlashlightOn ? 25 : 0;
            }

            if (isBlackout) {
                flashlight.intensity = 0; ambientLight.intensity = 0; playerLight.intensity = 0.02;
                if (Math.random() < 0.08) {
                    document.getElementById('curse-overlay').style.display = 'flex';
                    document.getElementById('curse-ghost').style.opacity = Math.random() * 0.45;
                } else { document.getElementById('curse-overlay').style.display = 'none'; }
            } else {
                ambientLight.intensity = 0x05 / 255; playerLight.intensity = 0.4;
                document.getElementById('curse-overlay').style.display = 'none';
            }

            let forward = new THREE.Vector3(0, 0, -1).applyAxisAngle(new THREE.Vector3(0, 1, 0), yaw).applyAxisAngle(new THREE.Vector3(1, 0, 0), pitch);
            flashlight.position.copy(camera.position); flashlight.target.position.copy(camera.position).add(forward);
        }

        window.addEventListener('keydown', (e) => {
            let k = e.key.toLowerCase(); keys[k] = true;
            if (k === 'q' && gameActive && !isDead && !isBlackout) { isFlashlightOn = !isFlashlightOn; playSwitchSound(); }
            if (k === 'e' && gameActive && !isDead) { checkHidingInteraction(); } 
        });
        window.addEventListener('keyup', (e) => { keys[e.key.toLowerCase()] = false; });

        window.addEventListener('mousemove', (e) => {
            if (document.pointerLockElement !== container) return;
            yaw -= e.movementX * 0.0022; pitch -= e.movementY * 0.0022;
            pitch = Math.max(-Math.PI / 2.8, Math.min(Math.PI / 2.8, pitch));
            camera.rotation.set(pitch, yaw, 0); 
        });

        document.getElementById('start-btn').addEventListener('click', () => {
            document.getElementById('start-screen').style.display = 'none'; initAudio(); resetToFloor(1); gameActive = true; container.requestPointerLock();
        });
        document.getElementById('diary-close-btn').addEventListener('click', () => {
            document.getElementById('diary-overlay').style.display = 'none'; gameActive = true; container.requestPointerLock();
        });
        document.getElementById('action-btn').addEventListener('click', () => {
            document.getElementById('screen-overlay').style.display = 'none';
            initAudio();
            let msgText = document.getElementById('msg').innerText;
            if (msgText.includes('脱出') || msgText.includes('消失') || msgText.includes('精神崩壊')) { resetToFloor(1); } else { resetToFloor(currentFloor + 1); }
            gameActive = true; container.requestPointerLock();
        });

        container.addEventListener('click', () => {
            if (gameActive && document.pointerLockElement !== container) container.requestPointerLock();
        });

        buildMazeObjects();

        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            const time = clock.getElapsedTime();
            const deltaTime = Math.min(0.1, clock.getDelta()); 

            if (gameActive && !isDead) {
                updateEnvironmentLights(time, deltaTime);
                updatePlayerMovement(time);
                updateChaserAI(time);
                checkItemCollisions();
            }

            if (gameActive && !isDead) {
                generateFaceTexture(time);
                chaserTexture.needsUpdate = true;
                drawHorrorFaceToCtx(gCtx, 600, 600, time);
            }
            
            if (isDead && document.getElementById('jumpscare-overlay').style.display === 'flex') {
                drawHorrorFaceToCtx(jsCtx, 600, 600, time);
            }

            if (gameActive) drawMinimap(time);

            if (!hasDiary) {
                diaryMesh.rotation.y += 0.02;
                diaryMesh.position.y = 0.3 + Math.sin(time * 3) * 0.06;
            }
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
