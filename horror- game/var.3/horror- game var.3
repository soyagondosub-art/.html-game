        function drawMinimap(time) {
            mCtx.fillStyle = '#050706'; mCtx.fillRect(0, 0, 170, 170);
            let rows = mapData.length; let cols = mapData[0].length;
            let cellW = 170 / cols; let cellH = 170 / rows;

            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    if (mapData[r][c] === 1) {
                        mCtx.fillStyle = 'rgba(120, 30, 30, 0.55)';
                        mCtx.fillRect(c * cellW, r * cellH, cellW - 1, cellH - 1);
                    } else if (c === config.startGrid.x && r === config.startGrid.z && currentFloor === 1) {
                        mCtx.strokeStyle = '#00ff66'; mCtx.lineWidth = 2;
                        mCtx.strokeRect(c * cellW + 1, r * cellH + 1, cellW - 2, cellH - 2);
                    }
                }
            }

            hidingPlacesInScene.forEach(hp => {
                mCtx.fillStyle = 'rgba(0, 255, 150, 0.4)';
                mCtx.fillRect(hp.gridX * cellW + 1, hp.gridZ * cellH + 1, cellW - 2, cellH - 2);
            });

            if (!hasDiary) {
                mCtx.fillStyle = '#ffcc00'; mCtx.beginPath();
                mCtx.arc((config.diaryGrid.x + 0.5) * cellW, (config.diaryGrid.z + 0.5) * cellH, cellW * 0.35, 0, Math.PI * 2); mCtx.fill();
            }

            let currentCycleTime = minimapGlobalTimer % 60; 
            let showChaserOnMinimap = (currentCycleTime < 12); 

            if (showChaserOnMinimap && !isBlackout) {
                let cx = (chaserPos.x / SCALE) * cellW; let cz = (chaserPos.z / SCALE) * cellH;
                mCtx.fillStyle = '#ff0033'; mCtx.shadowColor = '#ff0000'; mCtx.shadowBlur = 8;
                mCtx.beginPath(); mCtx.arc(cx, cz, cellW * 0.45, 0, Math.PI * 2); mCtx.fill();
                mCtx.shadowBlur = 0;
            }

            let px = (playerPos.x / SCALE) * cellW; let pz = (playerPos.z / SCALE) * cellH;
            mCtx.fillStyle = '#00ffaa'; mCtx.beginPath(); mCtx.arc(px, pz, cellW * 0.35, 0, Math.PI * 2); mCtx.fill();
            
            // 【修正：左右反転防止】白線の描画角度をプレイヤーの回転方向（-yaw）と完全に一致
            mCtx.strokeStyle = '#ffffff'; mCtx.lineWidth = 1.5; mCtx.beginPath();
            mCtx.moveTo(px, pz); 
