        // ミニマップ描画システム（リアル化改良版）
        function drawMinimap(time) {
            minimapGlobalTimer += 1;
            const canvas = document.getElementById('minimap');
            const ctx = canvas.getContext('2d');
            
            let isLarge = keys['m'];
            let size = isLarge ? 450 : 180;
            ctx.clearRect(0, 0, 450, 450); // キャンバス全体をクリア（450固定、残像防止）
            // ※ canvasの物理サイズは450x450固定、描画範囲(size)だけ変える

            let R = mapData.length; let C = mapData[0].length;
            let cellW = size / C; let cellH = size / R;

            // ─── 背景：未踏エリアは黒の霧 ───
            ctx.fillStyle = '#010301';
            ctx.fillRect(0, 0, size, size);

            // ─── 1パス目：通ったセルの塗り（壁・通路を区別） ───
            for (let r = 0; r < R; r++) {
                for (let c = 0; c < C; c++) {
                    if (!visitedMap[r][c]) continue;
                    let x = c * cellW, y = r * cellH;
                    if (mapData[r][c] === 1) {
                        // 壁：立体感のあるグラデーション
                        let gWall = ctx.createLinearGradient(x, y, x + cellW, y + cellH);
                        gWall.addColorStop(0, '#1c2e24');
                        gWall.addColorStop(1, '#0a130d');
                        ctx.fillStyle = gWall;
                        ctx.fillRect(x, y, cellW, cellH);
                        // 壁の上辺・左辺をわずかに明るく（立体エッジ）
                        ctx.strokeStyle = 'rgba(60,90,70,0.5)';
                        ctx.lineWidth = 0.8;
                        ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x+cellW,y); ctx.stroke();
                        ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x,y+cellH); ctx.stroke();
                    } else {
                        // 通路：薄い緑がかった暗色
                        ctx.fillStyle = '#081209';
                        ctx.fillRect(x, y, cellW, cellH);
                        // 隣接した壁との境界線（床の縁取り）
                        ctx.strokeStyle = 'rgba(0,80,30,0.25)';
                        ctx.lineWidth = 0.5;
                        ctx.strokeRect(x + 0.25, y + 0.25, cellW - 0.5, cellH - 0.5);
                    }
                }
            }

            // ─── 霧の境界をぼかすグラデーションオーバーレイ ───
            for (let r = 0; r < R; r++) {
                for (let c = 0; c < C; c++) {
                    if (!visitedMap[r][c]) continue;
                    // 未訪問の隣接セルに向けてフォグフェード
                    let hasUnvisitedNeighbor = false;
                    for (let [dr,dc] of [[-1,0],[1,0],[0,-1],[0,1]]) {
                        let nr = r+dr, nc = c+dc;
                        if (nr<0||nr>=R||nc<0||nc>=C||!visitedMap[nr][nc]) { hasUnvisitedNeighbor = true; break; }
                    }
                    if (hasUnvisitedNeighbor) {
                        let x = c*cellW, y = r*cellH;
                        let fog = ctx.createRadialGradient(x+cellW/2, y+cellH/2, 0, x+cellW/2, y+cellH/2, cellW*1.2);
                        fog.addColorStop(0, 'rgba(0,0,0,0)');
                        fog.addColorStop(1, 'rgba(1,3,1,0.55)');
                        ctx.fillStyle = fog;
                        ctx.fillRect(x-cellW*0.5, y-cellH*0.5, cellW*2, cellH*2);
                    }
                }
            }

            // ─── 隠れ場所アイコン（棚:青, クローゼット:紫） ───
            for (let p of hidingPlacesInScene) {
                let gridX = Math.floor((p.x + SCALE/2) / SCALE);
                let gridZ = Math.floor((p.z + SCALE/2) / SCALE);
                if (!visitedMap[gridZ][gridX]) continue;
                let ix = (gridX + 0.5) * cellW, iy = (gridZ + 0.5) * cellH;
                let r = isLarge ? 5.5 : 2.8;
                // ドットグロウ
                let gItem = ctx.createRadialGradient(ix,iy,0,ix,iy,r*2.5);
                let col = p.type === 'shelf' ? '40,100,255' : '160,60,220';
                gItem.addColorStop(0, `rgba(${col},0.8)`);
                gItem.addColorStop(1, `rgba(${col},0)`);
                ctx.fillStyle = gItem; ctx.beginPath(); ctx.arc(ix,iy,r*2.5,0,Math.PI*2); ctx.fill();
                ctx.fillStyle = p.type === 'shelf' ? '#4488ff' : '#aa44ee';
                ctx.beginPath(); ctx.arc(ix,iy,r,0,Math.PI*2); ctx.fill();
                if (isLarge) {
                    ctx.fillStyle = 'rgba(200,220,255,0.85)';
                    ctx.font = `bold ${Math.floor(cellH*0.55)}px "Courier New"`;
                    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                    ctx.fillText(p.type === 'shelf' ? '棚' : '戸', ix, iy);
                }
                // アイテムあり：黄色の星マーク
                if (p.hasItem) {
                    ctx.fillStyle = '#ffee00';
                    ctx.font = `${isLarge ? 9 : 5}px serif`;
                    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                    ctx.fillText('★', ix + (isLarge?7:4), iy - (isLarge?7:4));
                }
            }

            // ─── スタート位置（鍵がかかっているなら南京錠アイコン） ───
            let sX = config.startGrid.x * cellW, sZ = config.startGrid.z * cellH;
            let isLocked = (hasDiary && doorLocked);
            let startGrad = ctx.createLinearGradient(sX, sZ, sX+cellW, sZ+cellH);
            startGrad.addColorStop(0, isLocked ? 'rgba(255,180,0,0.9)' : 'rgba(0,255,60,0.9)');
            startGrad.addColorStop(1, isLocked ? 'rgba(180,100,0,0.5)' : 'rgba(0,120,40,0.5)');
            ctx.strokeStyle = isLocked ? '#ffcc00' : '#00ff44';
            ctx.lineWidth = isLarge ? 3.5 : 2.0;
            ctx.shadowColor = isLocked ? '#ffcc00' : '#00ff44';
            ctx.shadowBlur = isLarge ? 10 : 5;
            ctx.strokeRect(sX+1, sZ+1, cellW-2, cellH-2);
            ctx.shadowBlur = 0;
            if (isLarge) {
                ctx.fillStyle = isLocked ? '#ffcc00' : '#00ff88';
                ctx.font = `bold ${Math.floor(cellH*0.65)}px serif`;
                ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                ctx.fillText(isLocked ? '🔒' : 'OUT', sX+cellW/2, sZ+cellH/2);
            }

            // ─── 日記アイコン（未回収かつ解放済み） ───
            if (!hasDiary && visitedMap[config.diaryGrid.z][config.diaryGrid.x]) {
                let dX = (config.diaryGrid.x + 0.5) * cellW;
                let dZ = (config.diaryGrid.z + 0.5) * cellH;
                let pulse = 0.55 + Math.sin(time * 5) * 0.45; // 滑らかな脈動
                let dR = (isLarge ? 8 : 4) * (0.85 + pulse * 0.15);
                // グロウ
                let dGrad = ctx.createRadialGradient(dX,dZ,0,dX,dZ,dR*3);
                dGrad.addColorStop(0, `rgba(255,230,0,${0.6*pulse})`);
                dGrad.addColorStop(1, 'rgba(255,180,0,0)');
                ctx.fillStyle = dGrad; ctx.beginPath(); ctx.arc(dX,dZ,dR*3,0,Math.PI*2); ctx.fill();
                ctx.fillStyle = `rgba(255,${180+Math.floor(pulse*75)},0,1)`;
                ctx.beginPath(); ctx.arc(dX,dZ,dR,0,Math.PI*2); ctx.fill();
                if (isLarge) {
                    ctx.fillStyle = '#fff';
                    ctx.font = `bold ${Math.floor(cellH*0.7)}px serif`;
                    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                    ctx.fillText('📓', dX, dZ);
                }
            }

            // ─── プレイヤーアバター（方向矢印付き） ───
            let pGridX = (playerPos.x + SCALE/2) / SCALE;
            let pGridZ = (playerPos.z + SCALE/2) / SCALE;
            let px = pGridX * cellW, pz = pGridZ * cellH;
            let pR = isLarge ? 7 : 4;

            ctx.save(); ctx.translate(px, pz); ctx.rotate(-yaw);
            // プレイヤーグロウ
            let pGlow = ctx.createRadialGradient(0,0,0,0,0,pR*3);
            pGlow.addColorStop(0, 'rgba(0,255,170,0.5)');
            pGlow.addColorStop(1, 'rgba(0,255,170,0)');
            ctx.fillStyle = pGlow; ctx.beginPath(); ctx.arc(0,0,pR*3,0,Math.PI*2); ctx.fill();
            // 本体三角形
            ctx.fillStyle = isSprinting ? '#ffff00' : '#00ffaa';
            ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.0;
            ctx.beginPath();
            ctx.moveTo(0, -pR*1.5);
            ctx.lineTo(-pR, pR);
            ctx.lineTo(pR, pR);
            ctx.closePath(); ctx.fill(); ctx.stroke();
            // 視線ライン
            ctx.strokeStyle = 'rgba(255,255,255,0.6)'; ctx.lineWidth = 1.2;
            ctx.beginPath(); ctx.moveTo(0,-pR*1.5); ctx.lineTo(0,-pR*3.5); ctx.stroke();
            ctx.restore();

            // ─── 敵マーカー（接近・追跡中） ───
            chasers.forEach(chaser => {
                let cGridX = (chaser.mesh.position.x + SCALE/2) / SCALE;
                let cGridZ = (chaser.mesh.position.z + SCALE/2) / SCALE;
                let cx = cGridX * cellW, cz = cGridZ * cellH;
                let dx = playerPos.x - chaser.mesh.position.x;
                let dz = playerPos.z - chaser.mesh.position.z;
                let dist = Math.sqrt(dx*dx+dz*dz);

                if (dist < SCALE * 4.5 || chaser.isChasing || activeBuff === 'exposed') {
                    let isCheeg = chaser.type === 'cheegyu';
                    let baseCol = isCheeg ? '255,100,0' : '255,0,40';
                    // パルスリング
                    let pulseT = (minimapGlobalTimer % 40) / 40;
                    let pulseR = pulseT * (isLarge ? 28 : 14);
                    ctx.strokeStyle = `rgba(${baseCol},${1-pulseT})`;
                    ctx.lineWidth = isLarge ? 2.0 : 1.0;
                    ctx.beginPath(); ctx.arc(cx, cz, pulseR+3, 0, Math.PI*2); ctx.stroke();
                    // 外リング（二重）
                    ctx.strokeStyle = `rgba(${baseCol},0.35)`;
                    ctx.lineWidth = 1.0;
                    ctx.beginPath(); ctx.arc(cx, cz, (isLarge?18:9), 0, Math.PI*2); ctx.stroke();
                    // 中心ドット（グロウ付き）
                    let eGlow = ctx.createRadialGradient(cx,cz,0,cx,cz,isLarge?14:7);
                    eGlow.addColorStop(0, `rgba(${baseCol},0.9)`);
                    eGlow.addColorStop(1, `rgba(${baseCol},0)`);
                    ctx.fillStyle = eGlow; ctx.beginPath(); ctx.arc(cx,cz,isLarge?14:7,0,Math.PI*2); ctx.fill();
                    ctx.fillStyle = isCheeg ? '#ff7700' : '#ff0033';
                    ctx.beginPath(); ctx.arc(cx, cz, isLarge?6:3.5, 0, Math.PI*2); ctx.fill();
                    // 追跡中：感嘆符
                    if (chaser.isChasing && isLarge) {
                        ctx.fillStyle = '#ff0000';
                        ctx.font = 'bold 13px monospace';
                        ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
                        ctx.fillText('!', cx, cz - 8);
                    }
                }
            });

            // ─── スキャンラインエフェクト（ホラー感） ───
            ctx.fillStyle = 'rgba(0,20,10,0.06)';
            for (let y = 0; y < size; y += 3) {
                ctx.fillRect(0, y, size, 1);
            }

            // ─── ミニマップ縁ノイズ（不安定感） ───
            if (!isLarge && chasers.some(c=>c.isChasing)) {
                ctx.strokeStyle = `rgba(255,0,0,${0.3 + Math.sin(time*8)*0.3})`;
                ctx.lineWidth = 2;
                ctx.strokeRect(0,0,size,size);
            }
        }





