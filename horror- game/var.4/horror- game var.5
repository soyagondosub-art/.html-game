        // 家具（棚・クローゼット）グラフィック向上＋裏表デザインシステム
        function createHidingPlaceMesh(x, z, type, colorHex) {
            let group = new THREE.Group();
            group.position.set(x, 0, z);

            let mainMat = new THREE.MeshStandardMaterial({ color: colorHex, roughness: 0.6, metalness: 0.2 });
            let backMat = new THREE.MeshStandardMaterial({ color: 0x15110d, roughness: 0.9 }); // 裏面用ダークカラー
            let insideMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.9 });

            // 本体枠組み
            let bodyGeo = type === 'shelf' ? new THREE.BoxGeometry(1.6, 2.0, 0.7) : new THREE.BoxGeometry(1.4, 2.2, 1.1);
            
            // 表裏表現を上げるためマルチマテリアル化 (0:右, 1:左, 2:上, 3:下, 4:正面(表), 5:背面(裏))
            let materials = [mainMat, mainMat, mainMat, mainMat, mainMat, backMat];
            let bodyMesh = new THREE.Mesh(bodyGeo, materials);
            bodyMesh.position.y = type === 'shelf' ? 1.0 : 1.1;
            bodyMesh.castShadow = true;
            bodyMesh.receiveShadow = true;
            group.add(bodyMesh);

            // 内包アイテム（開けたときランダム出現用・アイテム種別対応グラフィック）
            // アイテムは後でhasItemが決まってから種別に応じて差し替える。暫定でグループ用意。
            let itemGroup = new THREE.Group();
            itemGroup.position.set(0, 0.85, 0);
            itemGroup.visible = false;

            // コアオーブ（全種共通の光る球体）
            let coreGeo = new THREE.SphereGeometry(0.14, 16, 16);
            let coreMat = new THREE.MeshStandardMaterial({
                color: 0x00ffaa, emissive: 0x00ffaa, emissiveIntensity: 0.9,
                roughness: 0.1, metalness: 0.4, transparent: true, opacity: 0.92
            });
            let coreMesh = new THREE.Mesh(coreGeo, coreMat);
            itemGroup.add(coreMesh);

            // リングエフェクト（回転するトーラス）
            let ringGeo = new THREE.TorusGeometry(0.22, 0.025, 8, 24);
            let ringMat = new THREE.MeshBasicMaterial({ color: 0x00ffaa, transparent: true, opacity: 0.7 });
            let ringMesh = new THREE.Mesh(ringGeo, ringMat);
            ringMesh.rotation.x = Math.PI / 2;
            itemGroup.add(ringMesh);

            // 小さな浮遊パーティクル（4点）
            for (let pi = 0; pi < 4; pi++) {
                let pGeo = new THREE.SphereGeometry(0.03, 6, 6);
                let pMat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.8 });
                let pMesh = new THREE.Mesh(pGeo, pMat);
                let angle = (pi / 4) * Math.PI * 2;
                pMesh.position.set(Math.cos(angle) * 0.28, Math.sin(angle * 0.5) * 0.12, Math.sin(angle) * 0.28);
                pMesh.userData.orbitAngle = angle;
                itemGroup.add(pMesh);
            }

            // ポイントライト（アイテムが光を放つ）
            let itemLight = new THREE.PointLight(0x00ffaa, 0.0, 2.0);
            itemGroup.add(itemLight);

            group.add(itemGroup);
            let innerItemMesh = itemGroup; // 後方互換のため
            // coreMat/ringMatへの参照を保存
            itemGroup.userData = { coreMat, ringMat, ringMesh, itemLight };

            scene.add(group);
            mazeObjects.push(group);

            // アイテムの抽選システム（50%の確率でアイテムがセットされる）
            let itemPool = ['speed', 'invisible', 'fake_speed', 'fake_invisible'];
            let hiddenItem = Math.random() < 0.5 ? itemPool[Math.floor(Math.random() * itemPool.length)] : null;

            // アイテム種別に応じてグラフィック色を差し替え
            if (hiddenItem && innerItemMesh.userData) {
                let { coreMat, ringMat, itemLight } = innerItemMesh.userData;
                if (hiddenItem === 'speed' || hiddenItem === 'fake_speed') {
                    // 速度系：黄金色
                    coreMat.color.setHex(0xffcc00); coreMat.emissive.setHex(0xff8800);
                    ringMat.color.setHex(0xffdd00); itemLight.color.setHex(0xffaa00);
                } else if (hiddenItem === 'invisible' || hiddenItem === 'fake_invisible') {
                    // 透明系：青紫
                    coreMat.color.setHex(0x8844ff); coreMat.emissive.setHex(0x4400cc);
                    ringMat.color.setHex(0xaa66ff); itemLight.color.setHex(0x6622ff);
                }
                // 偽物は外見では区別できない（騙し設計）
            }

            hidingPlacesInScene.push({ 
                x: x, z: z, 
                type: type, 
                mesh: group, 
                itemMesh: innerItemMesh,
                hasItem: hiddenItem, 
                isOpen: false 
            });
        }

        function buildMazeObjects() {
            mazeObjects.forEach(obj => scene.remove(obj));
            mazeObjects = [];
            hidingPlacesInScene = [];

            let R = mapData.length;
            let C = mapData[0].length;

            for (let r = 0; r < R; r++) {
                for (let c = 0; c < C; c++) {
                    let val = mapData[r][c];
                    let x = c * SCALE;
                    let z = r * SCALE;

                    let fMesh = new THREE.Mesh(floorGeo, floorMat);
                    fMesh.rotation.x = -Math.PI / 2;
                    fMesh.position.set(x, 0, z);
                    fMesh.receiveShadow = true;
                    scene.add(fMesh);
                    mazeObjects.push(fMesh);

                    let cMesh = new THREE.Mesh(floorGeo, ceilMat);
                    cMesh.rotation.x = Math.PI / 2;
                    cMesh.position.set(x, SCALE, z);
                    cMesh.receiveShadow = true;
                    scene.add(cMesh);
                    mazeObjects.push(cMesh);

                    if (val === 1) {
                        let wMesh = new THREE.Mesh(wallGeo, wallMat);
                        wMesh.position.set(x, SCALE / 2, z);
                        wMesh.castShadow = true;
                        wMesh.receiveShadow = true;
                        scene.add(wMesh);
                        mazeObjects.push(wMesh);
                    }
                    else if (val === 2) {
                        createHidingPlaceMesh(x, z, 'shelf', 0x4a321a);
                    }
                    else if (val === 3) {
                        createHidingPlaceMesh(x, z, 'closet', 0x1f1f1f);
                    }
                }
            }

            let sX = config.startGrid.x * SCALE;
            let sZ = config.startGrid.z * SCALE;
            const startGeo = new THREE.PlaneGeometry(SCALE * 0.9, SCALE * 0.9);
            const startMat = new THREE.MeshBasicMaterial({ color: 0x00ff00, wireframe: true, side: THREE.DoubleSide });
            startZoneMesh = new THREE.Mesh(startGeo, startMat);
            startZoneMesh.rotation.x = -Math.PI / 2;
            startZoneMesh.position.set(sX, 0.01, sZ);
            scene.add(startZoneMesh);
            mazeObjects.push(startZoneMesh);

            let dX = config.diaryGrid.x * SCALE;
            let dZ = config.diaryGrid.z * SCALE;
            const diaryGeo = new THREE.BoxGeometry(0.35, 0.06, 0.45);
            const diaryMat = new THREE.MeshStandardMaterial({ color: 0xffaa00, emissive: 0x442200, roughness: 0.5 });
            diaryMesh = new THREE.Mesh(diaryGeo, diaryMat);
            diaryMesh.position.set(dX, 0.3, dZ);
            diaryMesh.castShadow = true;
            scene.add(diaryMesh);
            mazeObjects.push(diaryMesh);
        }

        function createChaserData(type, startGrid, textureCanvas, speed) {
            let tex = new THREE.CanvasTexture(textureCanvas);
            let mat = new THREE.MeshBasicMaterial({ map: tex, side: THREE.DoubleSide, transparent: true });
            let geom = new THREE.PlaneGeometry(2.0, 2.0);
            let mesh = new THREE.Mesh(geom, mat);
            scene.add(mesh);

            return {
                type: type,
                mesh: mesh,
                texture: tex,
                canvas: textureCanvas,
                pos: { x: startGrid.x * SCALE, z: startGrid.z * SCALE },
                targetNode: { x: startGrid.x, z: startGrid.z },
                isChasing: false,
                isBreakingIn: false,
                speed: speed,
                nextFootTime: 0
            };
        }

        function initPlayerAndChaserPositions() {
            playerPos.x = config.startGrid.x * SCALE;
            playerPos.z = config.startGrid.z * SCALE;
            playerPos.y = PLAYER_HEIGHT;
            yaw = 0; pitch = 0;
            camera.rotation.set(0,0,0);

            initVisitedMap();

            // エネミー群クリア
            chasers.forEach(c => scene.remove(c.mesh));
            chasers = [];

            // 1, 2階はクロセ単体、3階はクロセ＋田中チー牛の化け物（画像再現）のダブル襲撃システム
            let chaserSpeedBase = 0.026;
            
            // クロセ配置
            chasers.push(createChaserData('kurose', config.diaryGrid, chaserCanvases.kurose, chaserSpeedBase));
            
            // 3階限定：田中チー牛の化け物の追加投入
            if (currentFloor === 3) {
                let spawnNode = { x: 10, z: 9 }; // 中央付近から挟み撃ち
                chasers.push(createChaserData('cheegyu', spawnNode, chaserCanvases.cheegyu, chaserSpeedBase * 1.1));
            }

            flashlightMalfunctionTimer = 0;
            isFlashlightMalfunctioning = false;
            nextMalfunctionTime = 10.0 + Math.random() * 15.0; 

            // アイテムリセット
            currentItem = null;
            activeBuff = null;
            itemBuffTimer = 0;
            updateItemUI();
        }

        function updateEnvironmentLights(time, deltaTime) {
            blackoutCycleTimer += deltaTime;
            
            if (!isBlackout) {
                flashlightMalfunctionTimer += deltaTime;
                if (!isFlashlightMalfunctioning && flashlightMalfunctionTimer >= nextMalfunctionTime) {
                    isFlashlightMalfunctioning = true;
                    flashlightMalfunctionTimer = 0;
                    playSwitchSound(); 
                }
                if (isFlashlightMalfunctioning && flashlightMalfunctionTimer > 3.5) { 
                    isFlashlightMalfunctioning = false;
                    flashlightMalfunctionTimer = 0;
                    nextMalfunctionTime = 15.0 + Math.random() * 20.0; 
                    playSwitchSound();
                }
            }

            if (blackoutCycleTimer < 25.0) {
                isBlackout = false; hasPlayedWarningSound = false;
            } else if (blackoutCycleTimer < 28.0) {
                if (!hasPlayedWarningSound) { playSparkSound(); hasPlayedWarningSound = true; }
                isBlackout = (Math.floor(time * 12) % 2 === 0); 
            } else if (blackoutCycleTimer < 36.0) {
                isBlackout = true;
            } else {
                blackoutCycleTimer = 0; isBlackout = false; playSparkSound();
            }

            if (isBlackout) {
                ambientLight.intensity = 0.0; emergencyLight.intensity = 0.0; flashlight.intensity = 0.0;
                document.getElementById('game-body').classList.add('blackout-glitch');
                return;
            }

            document.getElementById('game-body').classList.remove('blackout-glitch');
            ambientLight.intensity = 1.0; emergencyLight.intensity = 0.35;

            if (isFlashlightOn && !isHiding && !isFlashlightMalfunctioning) {
                flashlight.intensity = 25.0; 
            } else {
                flashlight.intensity = 0.0;
            }

            emergencyLight.position.set(playerPos.x, SCALE - 0.2, playerPos.z);
            flashlight.position.set(camera.position.x, camera.position.y - 0.1, camera.position.z);
            const dir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
            flashlight.target.position.copy(flashlight.position).add(dir);
        }

        function checkCollision(nx, nz) {
            let buffer = 0.38;
            let grids = [
                { r: Math.floor((nz - buffer + SCALE/2) / SCALE), c: Math.floor((nx - buffer + SCALE/2) / SCALE) },
                { r: Math.floor((nz - buffer + SCALE/2) / SCALE), c: Math.floor((nx + buffer + SCALE/2) / SCALE) },
                { r: Math.floor((nz + buffer + SCALE/2) / SCALE), c: Math.floor((nx - buffer + SCALE/2) / SCALE) },
                { r: Math.floor((nz + buffer + SCALE/2) / SCALE), c: Math.floor((nx + buffer + SCALE/2) / SCALE) }
            ];
            for (let g of grids) {
                if (g.r < 0 || g.r >= mapData.length || g.c < 0 || g.c >= mapData[0].length) return true;
                if (mapData[g.r][g.c] === 1) return true; 
            }
            return false;
        }

        function updatePlayerMovement(time, deltaTime) {
            // バフ・デバフのタイマー管理システム
            if (activeBuff) {
                itemBuffTimer -= deltaTime;
                if (itemBuffTimer <= 0) {
                    activeBuff = null;
                    document.getElementById('guide-notice').innerHTML = "アイテムの効果が切れた。";
                    updateItemUI();
                }
            }

            if (isHiding) {
                camera.position.set(playerPos.x, playerPos.y, playerPos.z);
                updateHidingPrompt();
                return;
            }

            isSprinting = (keys['shift'] && stamina > 0 && (keys['w'] || keys['s'] || keys['a'] || keys['d']));
            if (isSprinting) {
                stamina = Math.max(0, stamina - 0.38);
                if (stamina === 0) staminaExhausted = true;
            } else {
                stamina = Math.min(100, stamina + 0.18);
                if (stamina > 20) staminaExhausted = false;
            }
            document.getElementById('stamina-bar').style.width = stamina + '%';

            // スピードアイテム＆偽物デバフの速度倍率計算システム
            let speedModifier = 1.0;
            if (activeBuff === 'speed') speedModifier = 1.6; // 加速
            if (activeBuff === 'slow') speedModifier = 0.5;  // 偽物による鈍足化

            let currentSpeed = (isSprinting ? SPRINT_PLAYER_SPEED : BASE_PLAYER_SPEED) * speedModifier;
            if (staminaExhausted) currentSpeed = BASE_PLAYER_SPEED * 0.6 * speedModifier;

            let moveX = 0; let moveZ = 0;
            if (keys['w']) moveZ -= 1; if (keys['s']) moveZ += 1;
            if (keys['a']) moveX -= 1; if (keys['d']) moveX += 1;

            if (moveX !== 0 || moveZ !== 0) {
                let length = Math.sqrt(moveX * moveX + moveZ * moveZ);
                let frontX = Math.sin(yaw); let frontZ = Math.cos(yaw);
                let rightX = -Math.sin(yaw - Math.PI / 2); let rightZ = -Math.cos(yaw - Math.PI / 2);

                let dx = (moveX * rightX + moveZ * frontX) / length * currentSpeed;
                let dz = (moveX * rightZ + moveZ * frontZ) / length * currentSpeed;

                if (!checkCollision(playerPos.x + dx, playerPos.z)) playerPos.x += dx;
                if (!checkCollision(playerPos.x, playerPos.z + dz)) playerPos.z += dz;

                if (time > nextPlayerFootTime && !isJumping) {
                    playPlayerFootstep(isSprinting);
                    nextPlayerFootTime = time + (isSprinting ? 0.26 : 0.45);
                }
            }

            // ミニマップ解放（プレイヤー現在地マッピング）システム
            let pGridX = Math.floor((playerPos.x + SCALE/2) / SCALE);
            let pGridZ = Math.floor((playerPos.z + SCALE/2) / SCALE);
            
            // プレイヤーの周囲1マスを自動解放
            for(let r = -1; r <= 1; r++) {
                for(let c = -1; c <= 1; c++) {
                    let targetR = pGridZ + r;
                    let targetC = pGridX + c;
                    if(targetR >= 0 && targetR < mapData.length && targetC >= 0 && targetC < mapData[0].length) {
                        visitedMap[targetR][targetC] = true;
                    }
                }
            }

            if (isJumping) {
                playerPos.y += velocityY; velocityY += GRAVITY;
                if (playerPos.y <= PLAYER_HEIGHT) {
                    playerPos.y = PLAYER_HEIGHT; isJumping = false; velocityY = 0;
                    playPlayerFootstep(false, 1.4); 
                }
            }

            camera.position.set(playerPos.x, playerPos.y, playerPos.z);
            updateHidingPrompt();
        }

        function updateHidingPrompt() {
            let promptDiv = document.getElementById('hiding-prompt');
            let visionOverlay = document.getElementById('hiding-vision-overlay');

            if (isHiding) {
                promptDiv.style.display = 'block';
                promptDiv.innerHTML = '【Spaceキー】隠れ場所から出る';
                visionOverlay.style.display = 'block'; 
                return;
            }

            visionOverlay.style.display = 'none';
            activeHidingPlace = null;
            let closePlace = null; let minDist = 1.6; 

            for (let p of hidingPlacesInScene) {
                let dx = playerPos.x - p.x; let dz = playerPos.z - p.z;
                let d = Math.sqrt(dx*dx + dz*dz);
                if (d < minDist) { minDist = d; closePlace = p; }
            }

            if (closePlace) {
                activeHidingPlace = closePlace;
                promptDiv.style.display = 'block';
                let typeJa = closePlace.type === 'shelf' ? '棚' : 'クローゼット';
                
                if (!closePlace.isOpen) {
                    promptDiv.innerHTML = `【Eキー】${typeJa}の扉を開ける`;
                } else {
                    // アイテム未回収かつ格納されている場合、拾うガイドを統合
                    let itemNotice = closePlace.hasItem ? `<br><span style="color:#00ffaa; font-size:13px; font-weight:bold;">【Fキー】落ちているアイテムを拾う</span>` : "";
                    promptDiv.innerHTML = `【Spaceキー】${typeJa}の中に隠れる <br> 【Eキー】扉を閉める ${itemNotice}`;
                }
            } else {
                promptDiv.style.display = 'none';
            }
        }

