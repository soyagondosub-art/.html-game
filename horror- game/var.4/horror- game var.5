        // 追跡者キャンバス群（①クロセ用、②田中チー牛の化け物用）
        const chaserCanvases = { kurose: document.createElement('canvas'), cheegyu: document.createElement('canvas') };
        Object.values(chaserCanvases).forEach(c => { c.width = 512; c.height = 512; });

        // 画像名: "image_a4b561.png" の特徴（歪んだ不気味な白顔、非対称の漆黒眼窩、血まみれの歯並び）を再現
        function generateFaceTexture(canvas, type, time) {
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, 512, 512);
            let w = 512; let h = 512;
            ctx.fillStyle = '#000000'; ctx.fillRect(0, 0, w, h);
            
            let jtX = Math.sin(time * 15) * 3;
            let jtY = Math.cos(time * 12) * 3;

            // 顔の輪郭（田中チー牛はより歪んで縦長に）
            ctx.fillStyle = type === 'cheegyu' ? '#ebebeb' : '#d2dcd6';
            ctx.beginPath();
            if (type === 'cheegyu') {
                ctx.ellipse(w/2 + jtX, h/2 - 10 + jtY, 135, 230, 0.05, 0, Math.PI * 2); // 歪み
            } else {
                ctx.ellipse(w/2 + jtX, h/2 - 20 + jtY, 115, 200, 0, 0, Math.PI * 2);
            }
            ctx.fill();

            // 影
            let grad = ctx.createRadialGradient(w/2, h/2 - 20, 30, w/2, h/2 - 20, 220);
            grad.addColorStop(0, 'rgba(255,255,255,0)');
            grad.addColorStop(1, 'rgba(0,0,0,0.9)');
            ctx.fillStyle = grad; ctx.beginPath(); ctx.ellipse(w/2 + jtX, h/2 - 20 + jtY, 135, 230, 0, 0, Math.PI * 2); ctx.fill();

            // 髪の毛
            ctx.fillStyle = '#000000';
            for (let i = 0; i < 30; i++) {
                let hX = w/2 - 140 + i * 10;
                ctx.beginPath(); ctx.moveTo(hX, h/2 - 230); ctx.lineTo(hX + 6, h/2 - 110 + Math.cos(i) * 25); ctx.lineTo(hX + 12, h/2 - 230); ctx.fill();
            }

            // 眼窩 (image_a4b561.png 再現：左右非対称の漆黒の穴、視線が変な方向)
            let eyeY = h/2 - 50;
            ctx.fillStyle = '#000000';
            if (type === 'cheegyu') {
                ctx.beginPath(); ctx.ellipse(w/2 - 55 + jtX, eyeY - 10 + jtY, 32, 26, 0.1, 0, Math.PI * 2); ctx.fill(); // 左目巨大化
                ctx.beginPath(); ctx.ellipse(w/2 + 50 + jtX, eyeY + 5 + jtY, 24, 20, -0.1, 0, Math.PI * 2); ctx.fill();
            } else {
                ctx.beginPath(); ctx.ellipse(w/2 - 50 + jtX, eyeY + jtY, 26, 22, 0, 0, Math.PI * 2); ctx.fill();
                ctx.beginPath(); ctx.ellipse(w/2 + 50 + jtX, eyeY + jtY, 26, 22, 0, 0, Math.PI * 2); ctx.fill();
            }

            // 剥き出しの歯並び口元
            let mouthY = h/2 + 75;
            ctx.fillStyle = '#080000';
            ctx.beginPath(); ctx.ellipse(w/2 + jtX, mouthY + jtY, 100, 45, 0, 0, Math.PI * 2); ctx.fill();

            ctx.fillStyle = '#e0e0d0'; // 汚れた歯
            let totalTeeth = type === 'cheegyu' ? 16 : 12;
            for(let i=0; i<totalTeeth; i++) {
                let tX = w/2 - 85 + i * 11 + jtX;
                ctx.beginPath(); ctx.moveTo(tX, mouthY - 25); ctx.lineTo(tX + 4, mouthY - 2); ctx.lineTo(tX + 8, mouthY - 25); ctx.fill();
                ctx.beginPath(); ctx.moveTo(tX, mouthY + 25); ctx.lineTo(tX + 4, mouthY + 2); ctx.lineTo(tX + 8, mouthY + 25); ctx.fill();
            }
        }

        const jsCanvas = document.getElementById('jumpscare-canvas');
        const jsCtx = jsCanvas.getContext('2d');
        jsCanvas.width = 800; jsCanvas.height = 800;

        const ambientLight = new THREE.AmbientLight(0x0c0c0c); 
        scene.add(ambientLight);

        const emergencyLight = new THREE.PointLight(0xff1111, 0.35, 15);
        scene.add(emergencyLight);

        const flashlight = new THREE.SpotLight(0xffffff, 25.0, 20, Math.PI / 4.5, 0.6, 0.8);
        flashlight.castShadow = true;
        flashlight.shadow.mapSize.width = 512;
        flashlight.shadow.mapSize.height = 512;
        flashlight.shadow.camera.near = 0.2;
        flashlight.shadow.camera.far = 20;
        scene.add(flashlight);
        scene.add(flashlight.target);

        let mazeObjects = [];
        let diaryMesh = null;
        let startZoneMesh = null;

        const wallGeo = new THREE.BoxGeometry(SCALE, SCALE, SCALE);
        const wallMat = new THREE.MeshStandardMaterial({ color: 0x2b2b2b, roughness: 0.85, metalness: 0.1 }); 
        const floorGeo = new THREE.PlaneGeometry(SCALE, SCALE);
