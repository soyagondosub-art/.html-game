        // 画面端に目を光らせる
        function drawEyeGlow(canvasId, flip) {
            let c = document.getElementById(canvasId);
            if (!c) return;
            let ctx = c.getContext('2d');
            let w = 100, h = 50;
            ctx.clearRect(0, 0, w, h);
            if (flip) { ctx.save(); ctx.translate(w, 0); ctx.scale(-1, 1); }
            // 眼球
            ctx.fillStyle = '#000'; ctx.beginPath(); ctx.ellipse(50,25, 44,22, 0, 0, Math.PI*2); ctx.fill();
            // 虹彩
            let grad = ctx.createRadialGradient(50,25,2, 50,25,16);
            grad.addColorStop(0, '#ff0000'); grad.addColorStop(0.5, '#880000'); grad.addColorStop(1, '#220000');
            ctx.fillStyle = grad; ctx.beginPath(); ctx.ellipse(50,25,16,16,0,0,Math.PI*2); ctx.fill();
            // 瞳孔
            ctx.fillStyle = '#000'; ctx.beginPath(); ctx.ellipse(50,25,5,8,0,0,Math.PI*2); ctx.fill();
            // 光沢
            ctx.fillStyle = 'rgba(255,200,200,0.7)'; ctx.beginPath(); ctx.ellipse(56,20,3,2,0,0,Math.PI*2); ctx.fill();
            if (flip) ctx.restore();
        }

