        // ローマ字→ひらがな変換テーブル（ち=chi/ti, し=shi/si, つ=tsu/tu 等）
        const romajiMap = [
            // 長い組み合わせを先に（順序重要）
            ['chi','ち'],['tchi','っち'],['sha','しゃ'],['shi','し'],['shu','しゅ'],['sho','しょ'],
            ['tsu','つ'],['dzu','づ'],['dji','ぢ'],['dja','ぢゃ'],['dzu','づ'],
            ['cha','ちゃ'],['chu','ちゅ'],['cho','ちょ'],
            ['kya','きゃ'],['kyu','きゅ'],['kyo','きょ'],
            ['nya','にゃ'],['nyu','にゅ'],['nyo','にょ'],
            ['hya','ひゃ'],['hyu','ひゅ'],['hyo','ひょ'],
            ['mya','みゃ'],['myu','みゅ'],['myo','みょ'],
            ['rya','りゃ'],['ryu','りゅ'],['ryo','りょ'],
            ['gya','ぎゃ'],['gyu','ぎゅ'],['gyo','ぎょ'],
            ['bya','びゃ'],['byu','びゅ'],['byo','びょ'],
            ['pya','ぴゃ'],['pyu','ぴゅ'],['pyo','ぴょ'],
            ['tya','ちゃ'],['tyu','ちゅ'],['tyo','ちょ'],
            ['si','し'],['tu','つ'],['ti','ち'],['di','ぢ'],['du','づ'],['hu','ふ'],
            ['fu','ふ'],['ji','じ'],['zi','じ'],
            ['ka','か'],['ki','き'],['ku','く'],['ke','け'],['ko','こ'],
            ['sa','さ'],['su','す'],['se','せ'],['so','そ'],
            ['ta','た'],['te','て'],['to','と'],
            ['na','な'],['ni','に'],['nu','ぬ'],['ne','ね'],['no','の'],
            ['ha','は'],['hi','ひ'],['he','へ'],['ho','ほ'],
            ['ma','ま'],['mi','み'],['mu','む'],['me','め'],['mo','も'],
            ['ya','や'],['yu','ゆ'],['yo','よ'],
            ['ra','ら'],['ri','り'],['ru','る'],['re','れ'],['ro','ろ'],
            ['wa','わ'],['wi','ゐ'],['we','ゑ'],['wo','を'],['nn','ん'],
            ['ga','が'],['gi','ぎ'],['gu','ぐ'],['ge','げ'],['go','ご'],
            ['za','ざ'],['zu','ず'],['ze','ぜ'],['zo','ぞ'],
            ['da','だ'],['de','で'],['do','ど'],
            ['ba','ば'],['bi','び'],['bu','ぶ'],['be','べ'],['bo','ぼ'],
            ['pa','ぱ'],['pi','ぴ'],['pu','ぷ'],['pe','ぺ'],['po','ぽ'],
            ['a','あ'],['i','い'],['u','う'],['e','え'],['o','お'],
            ['n','ん'],
        ];

        function romajiToHiragana(str) {
            let s = str.toLowerCase();
            let result = '';
            let i = 0;
            while (i < s.length) {
                // っ：子音の連続（tt, kk, ss, ... ）
                if (i+1 < s.length && s[i] !== 'n' && s[i] === s[i+1] && 'bcdfghjklmnpqrstvwxyz'.includes(s[i])) {
                    result += 'っ'; i++; continue;
                }
                let found = false;
                for (let [rom, kana] of romajiMap) {
                    if (s.startsWith(rom, i)) {
                        result += kana; i += rom.length; found = true; break;
                    }
                }
                if (!found) { result += s[i]; i++; }
            }
            return result;
        }

        function normalizeInput(str) {
            // ひらがなをカタカナ変換して比較に使える形に、カタカナ→ひらがな正規化
            let h = romajiToHiragana(str);
            // カタカナ→ひらがな（念のため）
            h = h.replace(/[ァ-ヶ]/g, c => String.fromCharCode(c.charCodeAt(0) - 0x60));
            return h;
        }

        function checkTypingInput() {
            let inp = document.getElementById('typing-lock-input');
            let typed = inp.value;
            let target = lockPhrases[lockPhraseIndex];
            // ローマ字入力を正規化（日本語入力でもローマ字直打ちでも対応）
            let normalizedTyped = normalizeInput(typed);
            let normalizedTarget = normalizeInput(target);

            if (typed === target || normalizedTyped === normalizedTarget) {
                inp.classList.add('correct');
                playItemSound(false);
                lockPhraseIndex++;
                document.getElementById('lock-progress-num').innerText = lockPhraseIndex;

                if (lockPhraseIndex >= lockPhrases.length) {
                    // 全フレーズ解錠！
                    inp.value = '解錠完了……扉が軋みながら開いていく…';
                    setTimeout(() => {
                        document.getElementById('typing-lock-overlay').style.display = 'none';
                        doorLocked = false;
                        typingLockActive = false;
                        // プレイヤーをスタート地点から少しずらして即triggerを防ぐ
                        playerPos.x += 0.5;
                        gameActive = true;
                        container.requestPointerLock();
                        document.getElementById('guide-notice').innerHTML =
                            '<span style="color:#00ff88;font-size:15px;font-weight:bold;">🔓 扉が開いた！緑の脱出口へ走れ！！</span>';
                        playItemSound(false);
                    }, 1200);
                } else {
                    // 次のフレーズへ
                    setTimeout(() => showLockPhrase(), 600);
                }
            } else if (typed.length >= target.length || normalizedTyped.length >= normalizedTarget.length) {
                // 長さ足りてるのに不一致 → 間違い演出
                inp.classList.add('wrong');
                playItemSound(true);
                setTimeout(() => {
                    inp.classList.remove('wrong');
                    inp.value = '';
                }, 350);
            }
        }

