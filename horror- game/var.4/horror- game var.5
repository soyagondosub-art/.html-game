        function toggleHiding() {
            if (isHiding) {
                isHiding = false; isChaserBreakingIn = false; chaserBreakInTimer = 0;
                playDoorCreakSound(); return;
            }

            if (activeHidingPlace && activeHidingPlace.isOpen) {
                isHiding = true; activeHidingPlace.isOpen = false; activeHidingPlace.mesh.position.y = 0.0;
                // 透明化バフ中は見られながら隠れても即座にはバレない補正システム
                let anyChaserChasing = chasers.some(c => c.isChasing);
                hidingSpotted = anyChaserChasing && (activeBuff !== 'invisible'); 
                playDoorCreakSound();
            }
        }

        function getNeighbors(node) {
            let res = []; let dirs = [{x:0, z:1}, {x:0, z:-1}, {x:1, z:0}, {x:-1, z:0}];
            for(let d of dirs){
                let nx = node.x + d.x; let nz = node.z + d.z;
                if(nz >= 0 && nz < mapData.length && nx >= 0 && nx < mapData[0].length){
                    if(mapData[nz][nx] !== 1) res.push({x: nx, z: nz});
                }
            }
            return res;
        }

        function findPath(start, target) {
            let queue = [ [start] ]; let visited = new Set(); visited.add(`${start.x},${start.z}`);
            while(queue.length > 0){
                let path = queue.shift(); let curr = path[path.length - 1];
                if(curr.x === target.x && curr.z === target.z) return path;
                for(let n of getNeighbors(curr)){
                    let key = `${n.x},${n.z}`;
                    if(!visited.has(key)){ visited.add(key); queue.push([...path, n]); }
                }
            }
            return null; 
        }

        function updateChaserAI(time) {
            let anyChaserClose = false;

            chasers.forEach(chaser => {
                let dx = playerPos.x - chaser.mesh.position.x;
                let dz = playerPos.z - chaser.mesh.position.z;
                let dist = Math.sqrt(dx * dx + dz * dz);

                let pGridX = Math.floor((playerPos.x + SCALE/2) / SCALE);
                let pGridZ = Math.floor((playerPos.z + SCALE/2) / SCALE);
                let cGridX = Math.floor((chaser.mesh.position.x + SCALE/2) / SCALE);
                let cGridZ = Math.floor((chaser.mesh.position.z + SCALE/2) / SCALE);

                // 隠れ場所襲撃判定
                if (isHiding && activeHidingPlace) {
                    let hDist = Math.sqrt((activeHidingPlace.x - chaser.mesh.position.x) ** 2 + (activeHidingPlace.z - chaser.mesh.position.z) ** 2);
                    let suspicious = hidingSpotted || (hDist < SCALE * 1.5 && (isFlashlightOn || stamina < 85 || activeBuff === 'exposed'));

                    if (suspicious && hDist < SCALE * 1.1) {
                        chaser.isBreakingIn = true;
                        chaser.mesh.position.set(activeHidingPlace.x, 1.1, activeHidingPlace.z + 0.8);
                        chaser.mesh.lookAt(activeHidingPlace.x, 1.1, activeHidingPlace.z);
                        
                        if (time > nextKnockSoundTime) {
                            playViolentKnockSound(); nextKnockSoundTime = time + 0.07;
                            document.getElementById('guide-notice').innerHTML = `<span style="color:red; font-size:15px; font-weight:bold;">⚠️ ガタガタガタ！！扉をこじ開けようとしている！！！</span>`;
                        }
                        chaserBreakInTimer += 0.016; 
                        if (chaserBreakInTimer > 3.0) triggerJumpscare();
                        if (time > nextHeartbeatTime) { playHeartbeat(1.0); nextHeartbeatTime = time + 0.25; }
                        return; 
                    }
                }

                // アイテム効果（透明化 / 位置発覚）を加味した索敵システム
                let canHear = (!isHiding && isSprinting && dist < SCALE * 5.0 && activeBuff !== 'invisible');
                let hasLineOfSight = (dist < SCALE * 4.5 && !isBlackout && activeBuff !== 'invisible');
                
                // 偽物アイテムのデバフ「発光の呪い」は一発で感知される
                if (activeBuff === 'exposed' && dist < SCALE * 10.0) { hasLineOfSight = true; canHear = true; }

                if ((hasLineOfSight || canHear) && (!isHiding || hidingSpotted)) {
                    if(!chaser.isChasing) { chaser.isChasing = true; triggerSpeechOverlay(); }
                    chaser.targetNode.x = pGridX; chaser.targetNode.z = pGridZ;
                } else {
                    let curTdx = chaser.targetNode.x * SCALE - chaser.mesh.position.x;
                    let curTdz = chaser.targetNode.z * SCALE - chaser.mesh.position.z;
                    if (Math.sqrt(curTdx * curTdx + curTdz * curTdz) < 0.1) {
                        chaser.isChasing = false;
                        let R = mapData.length; let C = mapData[0].length;
                        let loopCount = 0;
                        while(loopCount < 40) {
                            let rx = Math.floor(Math.random() * C); let rz = Math.floor(Math.random() * R);
                            if(mapData[rz][rx] !== 1) { chaser.targetNode.x = rx; chaser.targetNode.z = rz; break; }
                            loopCount++;
                        }
                    }
                }

                let path = findPath({x: cGridX, z: cGridZ}, chaser.targetNode);
                let nextNode = (path && path.length > 1) ? path[1] : chaser.targetNode;

                let tx = nextNode.x * SCALE; let tz = nextNode.z * SCALE;
                let tdx = tx - chaser.mesh.position.x; let tdz = tz - chaser.mesh.position.z;
                let tdist = Math.sqrt(tdx * tdx + tdz * tdz);

                let currentChaserSpeed = chaser.isChasing ? chaser.speed * 1.55 : chaser.speed;
                if (isBlackout) currentChaserSpeed *= 0.7; 

                if (tdist > 0.02) {
                    chaser.mesh.position.x += (tdx / tdist) * currentChaserSpeed;
                    chaser.mesh.position.z += (tdz / tdist) * currentChaserSpeed;
                }

                chaser.mesh.position.y = 1.0 + Math.sin(time * 5 + (chaser.type==='cheegyu'?2:0)) * 0.06;
                chaser.mesh.lookAt(playerPos.x, chaser.mesh.position.y, playerPos.z);

                if (dist < SCALE * 3.0) anyChaserClose = true;
                if (dist < 0.95 && !isHiding) triggerJumpscare();

                // 足音同期
                if (time > chaser.nextFootTime && dist < 15.0) {
                    let fVol = Math.max(0, Math.min(1.0, 1.0 - (dist / 15.0)));
                    playChaserFootstep(fVol);
                    chaser.nextFootTime = time + (chaser.isChasing ? 0.24 : 0.5);
                }
            });

            // 心臓の鼓動・恐怖BGM同期用（最も近い怪異との距離を元に計算）
            let minDistToPlayer = Math.min(...chasers.map(c => {
                let dx = playerPos.x - c.mesh.position.x; let dz = playerPos.z - c.mesh.position.z;
                return Math.sqrt(dx*dx + dz*dz);
            }));

            let anyChaserChasing = chasers.some(c => c.isChasing);
            if (time > nextBgmStepTime) {
                playDynamicBgmStep(minDistToPlayer, anyChaserChasing);
                nextBgmStepTime = time + (anyChaserChasing ? 0.35 : 0.75);
            }
            if (time > nextHeartbeatTime) {
                let hVol = Math.max(0, Math.min(1.0, 1.0 - (minDistToPlayer / (SCALE * 5.0))));
                if (hVol > 0.02) playHeartbeat(hVol);
                nextHeartbeatTime = time + 0.9 - (hVol * 0.5);
            }

            document.getElementById('yusei-alert').style.display = anyChaserClose ? 'block' : 'none';
        }

        function triggerSpeechOverlay() {
            let overlay = document.getElementById('chaser-speech-overlay');
            if (overlay.style.display === 'block') return;
            overlay.innerHTML = horrorVoices[Math.floor(Math.random() * horrorVoices.length)];
