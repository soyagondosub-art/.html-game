        buildMazeObjects();

        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            const deltaTime = Math.min(0.1, clock.getDelta()); // getDelta を先に呼ぶ（二重消費防止）
            const time = clock.getElapsedTime();

            if (gameActive && !isDead) {
                updateEnvironmentLights(time, deltaTime);
                updatePlayerMovement(time, deltaTime);
                updateChaserAI(time);
                checkItemCollisions();
            }

            if (gameActive && !isDead) {
                chasers.forEach(c => {
                    generateFaceTexture(c.canvas, c.type, time);
                    c.texture.needsUpdate = true;
                });
            }
            
            if (isDead && document.getElementById('jumpscare-overlay').style.display === 'flex') {
                // デススクリーンの顔シミュレート
                const ctx = jsCtx; let w = 800; let h = 800;
                ctx.clearRect(0, 0, w, h);
                let jtX = Math.sin(time * 110) * 10; let jtY = Math.cos(time * 95) * 10;
                ctx.fillStyle = '#0a0101'; ctx.fillRect(0,0,w,h);
                ctx.fillStyle = '#e5e5e5'; ctx.beginPath(); ctx.ellipse(w/2+jtX, h/2-20+jtY, 190, 300, 0.04, 0, Math.PI*2); ctx.fill();
                ctx.fillStyle = '#000000'; ctx.beginPath(); ctx.ellipse(w/2-70+jtX, h/2-80+jtY, 45, 35, 0, 0, Math.PI*2); ctx.fill();
                ctx.beginPath(); ctx.ellipse(w/2+70+jtX, h/2-75+jtY, 35, 28, 0, 0, Math.PI*2); ctx.fill();
                ctx.beginPath(); ctx.ellipse(w/2+jtX, h/2+100+jtY, 130, 75, 0, 0, Math.PI*2); ctx.fill();
            }

            if (gameActive) drawMinimap(time);

            // ===== ホラー演出フック =====
            if (gameActive && !isDead) {
                let minD = chasers.length > 0 ? Math.min(...chasers.map(c => {
                    let dx = playerPos.x - c.mesh.position.x; let dz = playerPos.z - c.mesh.position.z;
                    return Math.sqrt(dx*dx + dz*dz);
                })) : 999;
                let anyChasing = chasers.some(c => c.isChasing);
                updateTimer(time); updateBestTimeDisplay();
                updateVignette(minD, anyChasing);
                updateEyeGlow(anyChasing, minD);
                updateBloodText(time, anyChasing);
                checkBlackoutTransition();
                updateScratchEffect(isHiding, minD);
                updateFogByTime(floorElapsed);

                // 追跡中にランダムグリッチ
                if (anyChasing && minD < SCALE * 4.0) {
                    glitchLineTimer += deltaTime;
                    if (glitchLineTimer > (0.8 + Math.random() * 1.2)) {
                        spawnGlitchLines(3 + Math.floor(Math.random() * 4));
                        glitchLineTimer = 0;
                    }
                }
            }

            if (!hasDiary && diaryMesh) {
                diaryMesh.rotation.y += 0.02; diaryMesh.position.y = 0.3 + Math.sin(time * 3) * 0.06;
            }

            // アイテムアニメーション（表示中のもの全て）
            hidingPlacesInScene.forEach(p => {
                if (p.isOpen && p.hasItem && p.itemMesh && p.itemMesh.visible) {
                    let ud = p.itemMesh.userData;
                    // グループ全体をゆっくり回転
                    p.itemMesh.rotation.y += 0.022;
                    // 上下浮遊
                    p.itemMesh.position.y = 0.85 + Math.sin(time * 2.5 + p.x) * 0.08;
                    // リングを逆回転
                    if (ud && ud.ringMesh) ud.ringMesh.rotation.z += 0.03;
                    // 子パーティクルを軌道回転
                    if (ud) {
                        p.itemMesh.children.forEach(child => {
                            if (child.userData && child.userData.orbitAngle !== undefined) {
                                child.userData.orbitAngle += 0.04;
                                let a = child.userData.orbitAngle;
                                child.position.set(Math.cos(a)*0.28, Math.sin(a*0.7)*0.12, Math.sin(a)*0.28);
                            }
                        });
                        // ライト強度を脈動
                        if (ud.itemLight) ud.itemLight.intensity = 0.9 + Math.sin(time * 4) * 0.4;
                    }
                }
            });
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
