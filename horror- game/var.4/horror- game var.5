            gain.gain.setValueAtTime(vol * 1.2, audioCtx.currentTime); 
            gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.12);
            osc.start(); osc.stop(audioCtx.currentTime + 0.15);
            setTimeout(() => {
                if (isDead || !masterGain) return;
