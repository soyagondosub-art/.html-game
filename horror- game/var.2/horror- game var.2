        function buildMazeObjects() {
            while(wallGroup.children.length > 0) { const obj = wallGroup.children[0]; wallGroup.remove(obj); }
            const mapW = mapData[0].length; const mapH = mapData.length;

            const fMesh = new THREE.Mesh(new THREE.PlaneGeometry(mapW * SCALE, mapH * SCALE), floorMat);
            fMesh.rotation.x = -Math.PI / 2; fMesh.position.set((mapW/2 - 0.5)*SCALE, 0, (mapH/2 - 0.5)*SCALE);
            fMesh.receiveShadow = true; wallGroup.add(fMesh);

            const cMesh = new THREE.Mesh(new THREE.PlaneGeometry(mapW * SCALE, mapH * SCALE), ceilingMat);
