            wallGroup.add(cMesh);

            for (let z = 0; z < mapH; z++) {
                for (let x = 0; x < mapW; x++) {
                    const type = mapData[z][x];
                    if (type === 1) {
                        const wall = new THREE.Mesh(wallGeom, wallMat); wall.position.set(x * SCALE, 2.0, z * SCALE);
                        wall.castShadow = true; wall.receiveShadow = true; wallGroup.add(wall);
                    } else if (type === 2 || type === 3) {
