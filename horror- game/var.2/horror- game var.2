        function triggerChaserTeleport() {
            if (isDead || !gameActive || isBlackout) return; 

            let dirX = -Math.sin(yaw);
            let dirZ = -Math.cos(yaw);

            let targetX = playerPos.x + dirX * (SCALE * 1.8);
            let targetZ = playerPos.z + dirZ * (SCALE * 1.8);

            let gridX = Math.round(targetX / SCALE);
            let gridZ = Math.round(targetZ / SCALE);
            
            if (gridX > 0 && gridX < mapData[0].length - 1 && gridZ > 0 && gridZ < mapData.length - 1) {
                if (mapData[gridZ][gridX] === 0) {
                    chaserPos.x = targetX;
                    chaserPos.z = targetZ;
                } else {
                    chaserPos.x = playerPos.x + dirX * SCALE;
                    chaserPos.z = playerPos.z * SCALE;
                }
            }

