        function updatePlayerMovement(time) {
            if (!gameActive || isDead) return;

            isSprinting = keys['ShiftLeft'] || keys['ShiftRight'];
            if (staminaExhausted) isSprinting = false;

            let baseSpeed = 0.034; 
            if (isSprinting && (keys['KeyW'] || keys['KeyS'] || keys['KeyA'] || keys['KeyD'])) {
                baseSpeed = 0.065; 
                stamina = Math.max(0, stamina - 0.8);
                if (stamina === 0) staminaExhausted = true;
            } else {
                stamina = Math.min(100, stamina + 0.18);
                if (stamina > 25) staminaExhausted = false;
            }
            
            document.getElementById('stamina-bar').style.width = stamina + '%';
            document.getElementById('stamina-bar').style.background = staminaExhausted ? '#ff3333' : '#00ffaa';

            let forwardX = -Math.sin(yaw); let forwardZ = -Math.cos(yaw);
            let rightX = Math.cos(yaw); let rightZ = -Math.sin(yaw);

            let moveX = 0, moveZ = 0;
            if (keys['KeyW']) { moveX += forwardX; moveZ += forwardZ; }
            if (keys['KeyS']) { moveX -= forwardX; moveZ -= forwardZ; }
            if (keys['KeyA']) { moveX -= rightX; moveZ -= rightZ; }
            if (keys['KeyD']) { moveX += rightX; moveZ += rightZ; }

            if (moveX !== 0 || moveZ !== 0) {
                const len = Math.sqrt(moveX * moveX + moveZ * moveZ);
                const dx = (moveX / len) * baseSpeed * SCALE;
                const dz = (moveZ / len) * baseSpeed * SCALE;

                const radius = SCALE * 0.28; 
                
                let testX = playerPos.x + dx;
                let gridX_forX = Math.round((testX + Math.sign(dx) * radius) / SCALE);
                let gridZ_forX = Math.round(playerPos.z / SCALE);
                if (checkPassable(Math.round(playerPos.x/SCALE), gridZ_forX, gridX_forX, gridZ_forX, dx, 0)) {
                    playerPos.x = testX;
                }
                
                let testZ = playerPos.z + dz;
                let gridX_forZ = Math.round(playerPos.x / SCALE);
                let gridZ_forZ = Math.round((testZ + Math.sign(dz) * radius) / SCALE);
                if (checkPassable(gridX_forZ, Math.round(playerPos.z/SCALE), gridX_forZ, gridZ_forZ, 0, dz)) {
                    playerPos.z = testZ;
                }

                if (!isJumping) {
                    let stepInterval = isSprinting ? 0.3 : 0.52; 
                    if (time > nextPlayerFootTime) {
                        playPlayerFootstep(isSprinting);
                        nextPlayerFootTime = time + stepInterval;
                    }
                }
            }

            if (isJumping) {
                velocityY += GRAVITY;
                playerPos.y += velocityY;
                
                if (playerPos.y <= PLAYER_HEIGHT) {
                    playerPos.y = PLAYER_HEIGHT;
                    isJumping = false;
                    velocityY = 0;
                    playPlayerFootstep(isSprinting, 1.5); 
                }
            }

            camera.position.set(playerPos.x, playerPos.y, playerPos.z);
            flashlight.position.copy(camera.position);
            const dir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
            flashlight.target.position.copy(camera.position).add(dir);

            let currentForwardVec = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
            currentForwardVec.y = 0; currentForwardVec.normalize(); 

            let dotProduct = currentForwardVec.dot(prevForwardVec);
            if (dotProduct < -0.7) {
                if (teleportCooldown <= 0) {
                    if (Math.random() < 0.15) {
                        triggerChaserTeleport(); 
                    }
                    teleportCooldown = 6.0; 
                }
            }
            prevForwardVec.copy(currentForwardVec);
        }

        // 🛑 壁の衝突判定（ジャンプ中のすり抜けバグ修正）
        function checkPassable(cx, cz, nx, nz, dx, dz) {
            if (nx < 0 || nx >= mapData[0].length || nz < 0 || nz >= mapData.length) return false;
            const targetCell = mapData[nz][nx];
            if (targetCell === 0) return true;
            if (targetCell === 1) return false;
            
            // 💡 プレイヤーの高さ（Y座標）に関わらず、壁があるセルの横移動制限を絶対化
            if (targetCell === 2) return (cz < nz && dz > 0);
            if (targetCell === 3) return (cz > nz && dz < 0);
            return false;
        }

        function checkLineOfSight() {
            let pGX = Math.round(playerPos.x / SCALE); let pGZ = Math.round(playerPos.z / SCALE);
            let cGX = Math.round(chaserPos.x / SCALE); let cGZ = Math.round(chaserPos.z / SCALE);
            let dx = Math.abs(pGX - cGX); let dy = Math.abs(pGZ - cGZ);
            let sx = (cGX < pGX) ? 1 : -1; let sy = (cGZ < pGZ) ? 1 : -1; let err = dx - dy;
            let x = cGX; let z = cGZ;
            while (true) {
                if (x === pGX && z === pGZ) break;
                if (x >= 0 && x < mapData[0].length && z >= 0 && z < mapData.length) {
                    if (mapData[z][x] === 1) return false; 
                }
                let e2 = 2 * err;
                if (e2 > -dy) { err -= dy; x += sx; }
                if (e2 < dx) { err += dx; z += sy; }
            }
            return true; 
        }

        function updateEnvironmentLights(time, deltaTime) {
            if (!gameActive || isDead) return;

            if (teleportCooldown > 0) teleportCooldown -= deltaTime;
            
            blackoutCycleTimer += deltaTime;

            if (blackoutCycleTimer >= 30.0) {
                blackoutCycleTimer = 0;
                isBlackout = false;
                hasPlayedWarningSound = false;
                playSparkSound(); 
            } else if (blackoutCycleTimer >= 28.0) {
                isBlackout = true;
                document.getElementById('game-body').classList.remove('blackout-glitch');
            } else if (blackoutCycleTimer >= 26.5) {
                if (!hasPlayedWarningSound) {
                    playSparkSound();
                    hasPlayedWarningSound = true;
                }
                document.getElementById('game-body').classList.add('blackout-glitch');
            } else {
                isBlackout = false;
                document.getElementById('game-body').classList.remove('blackout-glitch');
            }

            if (isBlackout) {
                scene.fog.density = 5.0;       
                flashlight.intensity = 0.0;    
                flashlight.visible = false; 
                ambientLight.intensity = 0.0;  
                document.getElementById('chaser-speech-overlay').style.display = 'none'; 
            } else {
                scene.fog.density = NORMAL_FOG_DENSITY;
                
                // 💡 懐中電灯ON/OFFスイッチの状態を適用
                if (isFlashlightOn) {
                    flashlight.intensity = 10.0;
                    flashlight.visible = true;
                } else {
                    flashlight.intensity = 0.0;
                    flashlight.visible = false;
                }
                
                ambientLight.intensity = 0.8; // 💡 明るさを0.8に固定
            }
        }

        function updateChaserAI(time) {
            if (isDead || !gameActive) return;

            const diffX = playerPos.x - chaserPos.x;
            const diffZ = playerPos.z - chaserPos.z;
            const dist = Math.sqrt(diffX*diffX + diffZ*diffZ);

            let isSighted = checkLineOfSight();

            if (time > nextBgmStepTime) {
                let severity = Math.max(0, Math.min(1.0, 1.0 - (dist / (SCALE * 6.5))));
                let bgmInterval = 0.75 - (severity * 0.52); 
                playDynamicBgmStep(dist, isSighted);
                nextBgmStepTime = time + bgmInterval;
            }

            document.getElementById('yusei-alert').style.display = (dist < SCALE * 4.0) ? 'block' : 'none';

            if (isSighted && dist < SCALE * 8.0 && !isBlackout) {
                if (!isChaserLookingAtPlayer) {
                    const randomIndex = Math.floor(Math.random() * horrorVoices.length);
                    document.getElementById('chaser-speech-overlay').innerText = horrorVoices[randomIndex];
                    isChaserLookingAtPlayer = true;
                }
                document.getElementById('chaser-speech-overlay').style.display = 'block';
            } else {
                if (!isChaserLookingAtPlayer || isBlackout) {
                    document.getElementById('chaser-speech-overlay').style.display = 'none';
                    isChaserLookingAtPlayer = false;
                }
            }

            const body = document.getElementById('game-body');
            if (dist < SCALE * 4.5 && !isBlackout) {
                document.getElementById('curse-overlay').style.display = 'flex';
                document.getElementById('curse-ghost').style.opacity = (1.0 - (dist / (SCALE*4.5))) * 0.07;
                if(dist < SCALE * 1.8) body.classList.add('glitch-active');
                else body.classList.remove('glitch-active');
            } else {
                document.getElementById('curse-overlay').style.display = 'none';
                if(!isBlackout) body.classList.remove('glitch-active');
            }

            if (audioCtx) {
                let heartbeatInterval = Math.max(0.2, Math.min(1.1, dist * 0.15));
                if (isChaserLookingAtPlayer && dist < SCALE * 3.0) heartbeatInterval = 0.22;
                if (time > nextHeartbeatTime) {
                    let vol = Math.max(0.1, 1.0 - (dist / (SCALE*6)));
                    playHeartbeat(vol); nextHeartbeatTime = time + heartbeatInterval;
                }
                if (time > nextChaserFootTime) {
                    let vol = Math.max(0.0, 1.0 - (dist / (SCALE*5)));
                    if(vol > 0.05) playChaserFootstep(vol);
                    nextChaserFootTime = time + 0.4;
                }
            }

            if (dist < 0.75) { triggerGameOver(); return; }

            if (currentFloor === 1) {
                let angle = Math.atan2(diffZ, diffX);
                let speedMultiplier = chaserSpeed * SCALE;
                chaserPos.x += Math.cos(angle) * speedMultiplier;
                chaserPos.z += Math.sin(angle) * speedMultiplier;
            } else {
                let mx = 0, mz = 0;
                if (Math.abs(diffX) > Math.abs(diffZ)) mx = Math.sign(diffX);
                else mz = Math.sign(diffZ);

                let actualSpeed = chaserSpeed * SCALE;
                let nX = chaserPos.x + mx * actualSpeed; let nZ = chaserPos.z + mz * actualSpeed;
                let cGX = Math.round(chaserPos.x / SCALE); let cGZ = Math.round(chaserPos.z / SCALE);
                let nGX = Math.round(nX / SCALE); let nGZ = Math.round(nZ / SCALE);

                let moved = false;
                if (mx !== 0 && checkPassable(cGX, cGZ, nGX, cGZ, mx, 0)) { chaserPos.x = nX; moved = true; }
                if (!moved && mz !== 0 && checkPassable(cGX, cGZ, cGX, nGZ, 0, mz)) { chaserPos.z = nZ; moved = true; }

                if (!moved) {
                    if (mx !== 0) {
                        let altZ = Math.sign(diffZ) || 1; let targetGZ = Math.round((chaserPos.z + altZ * actualSpeed) / SCALE);
                        if(checkPassable(cGX, cGZ, cGX, targetGZ, 0, altZ)) chaserPos.z += altZ * actualSpeed;
                    } else {
                        let altX = Math.sign(diffX) || 1; let targetGX = Math.round((chaserPos.x + altX * actualSpeed) / SCALE);
                        if(checkPassable(cGX, cGZ, targetGX, cGZ, altX, 0)) chaserPos.x += altX * actualSpeed;
                    }
                }
            }

            chaserMesh.position.set(chaserPos.x, 1.35, chaserPos.z);
            chaserMesh.quaternion.copy(camera.quaternion);
            chaserLight.position.set(chaserPos.x, 1.9, chaserPos.z);
        }

        const minimapCanvas = document.getElementById('minimap');
        const mCtx = minimapCanvas.getContext('2d');
        minimapCanvas.width = 170; minimapCanvas.height = 170;

        function drawMinimap(time) {
            mCtx.clearRect(0, 0, 170, 170);
            const mapW = mapData[0].length; const mapH = mapData.length;
            const cellSize = Math.min(170 / mapW, 170 / mapH);
            const offsetX = (170 - mapW * cellSize) / 2; const offsetY = (170 - mapH * cellSize) / 2;

            for (let z = 0; z < mapH; z++) {
                for (let x = 0; x < mapW; x++) {
                    if (mapData[z][x] === 1) mCtx.fillStyle = '#3a1f1f'; 
                    else if (mapData[z][x] === 2 || mapData[z][x] === 3) mCtx.fillStyle = '#2233aa'; 
                    else mCtx.fillStyle = '#1c2620'; 
                    mCtx.fillRect(offsetX + x * cellSize, offsetY + z * cellSize, cellSize, cellSize);
                    mCtx.strokeStyle = '#2d3d33'; mCtx.lineWidth = 0.5; mCtx.strokeRect(offsetX + x * cellSize, offsetY + z * cellSize, cellSize, cellSize);
                }
            }

            let pX = (playerPos.x / SCALE) * cellSize + offsetX; 
            let pZ = (playerPos.z / SCALE) * cellSize + offsetY;
            
            mCtx.save(); 
            mCtx.translate(pX, pZ);
            
            let viewAngle = -yaw - Math.PI / 2; 
            let scanCone = Math.PI / 2.8;
            let gradient = mCtx.createRadialGradient(0, 0, 2, 0, 0, cellSize * 4.5);
            gradient.addColorStop(0, 'rgba(0, 255, 150, 0.5)'); 
            gradient.addColorStop(0.4, 'rgba(0, 255, 150, 0.15)'); 
            gradient.addColorStop(1, 'rgba(0, 255, 150, 0)');
            mCtx.fillStyle = gradient; mCtx.beginPath(); mCtx.moveTo(0, 0); mCtx.arc(0, 0, cellSize * 4.5, viewAngle - scanCone/2, viewAngle + scanCone/2); mCtx.closePath(); mCtx.fill();
            mCtx.restore();

            let sX = config.startGrid.x * cellSize + offsetX; let sZ = config.startGrid.z * cellSize + offsetY;
            mCtx.strokeStyle = '#00ff88'; mCtx.lineWidth = 2; mCtx.strokeRect(sX + 1, sZ + 1, cellSize - 2, cellSize - 2);

            if (!hasDiary) {
                let dX = config.diaryGrid.x * cellSize + offsetX; let dZ = config.diaryGrid.z * cellSize + offsetY;
                mCtx.fillStyle = '#ffcc00'; mCtx.fillRect(dX + 2, dZ + 2, cellSize - 4, cellSize - 4);
            }

            mCtx.shadowBlur = 6; mCtx.shadowColor = '#00ffaa'; mCtx.fillStyle = '#00ffaa'; mCtx.beginPath(); mCtx.arc(pX, pZ, cellSize * 0.4, 0, Math.PI * 2); mCtx.fill(); mCtx.shadowBlur = 0; 

            let cX = (chaserPos.x / SCALE) * cellSize + offsetX; let cZ = (chaserPos.z / SCALE) * cellSize + offsetY;
            
            let pulseRadius = cellSize * 0.45 + Math.abs(Math.sin(time * 10)) * (cellSize * 0.25); 
            let pulseOpacity = 0.5 + Math.abs(Math.sin(time * 10)) * 0.5;
            mCtx.shadowBlur = 8; mCtx.shadowColor = '#ff0033'; mCtx.fillStyle = `rgba(255, 0, 50, ${pulseOpacity})`; mCtx.beginPath(); mCtx.arc(cX, cZ, pulseRadius, 0, Math.PI * 2); mCtx.fill(); mCtx.shadowBlur = 0; 
        }

        function checkItemCollisions() {
            if (isDead || !gameActive) return;
            let pGridX = Math.round(playerPos.x / SCALE); let pGridZ = Math.round(playerPos.z / SCALE);

            if (!hasDiary && pGridX === config.diaryGrid.x && pGridZ === config.diaryGrid.z) {
                hasDiary = true; diaryMesh.visible = false; diaryLight.visible = false;
                gameActive = false; document.exitPointerLock();
                document.getElementById('diary-content').innerText = diaryTexts[currentFloor];
                document.getElementById('diary-overlay').style.display = 'flex';
            }
            if (hasDiary && pGridX === config.startGrid.x && pGridZ === config.startGrid.z) {
                triggerFloorClear();
            }
        }

        document.getElementById('diary-close-btn').addEventListener('click', () => {
            document.getElementById('diary-overlay').style.display = 'none';
            gameActive = true; document.body.requestPointerLock();
        });

        function triggerFloorClear() {
            gameActive = false; document.exitPointerLock();
            if (currentFloor < 3) {
                currentFloor++; mapData = mazes[currentFloor]; config = floorConfigs[currentFloor];
                chaserSpeed = 0.013; 
                document.getElementById('msg').innerHTML = `<span style="color:#00ff88;">【階層突破】</span><br><br>無事に日記を確保し、次の階への階段を見つけた。<br>しかし、田中チー牛１１歳の姿はまだない……。<br>ここからは追跡速度が上昇(0.013)し、BGMの狂いも早くなる！`;
                document.getElementById('action-btn').innerText = `${currentFloor}階の深淵へ`;
                document.getElementById('floor-display').innerText = `【現在位置: 廃病院 ${currentFloor}階】`;
                hasDiary = false; buildMazeObjects(); resetPlayer(); initChaserPosition();
                document.getElementById('screen-overlay').style.display = 'flex';
            } else {
                document.getElementById('msg').innerHTML = `<span style="color:#ffff00; font-size:36px; text-shadow:0 0 20px #ffaa00;">🎉 脱出成功 🎉</span><br><br>すべての真実が記された日記を持ち、君は生きて廃病院を脱出した！<br>度重なる完全停電の恐怖にも、君の精神は屈しなかった。<br><br><span style="color:#00ffaa;">GAME CLEAR. おめでとうございます！</span>`;
                document.getElementById('action-btn').innerText = "最初から挑戦する";
                currentFloor = 1; mapData = mazes[currentFloor]; config = floorConfigs[currentFloor]; 
                chaserSpeed = 0.009; hasDiary = false; buildMazeObjects(); resetPlayer(); initChaserPosition();
                document.getElementById('screen-overlay').style.display = 'flex';
            }
        }

        function triggerGameOver() {
            isDead = true; gameActive = false;
            document.exitPointerLock();
            document.getElementById('game-body').classList.remove('glitch-active');
            document.getElementById('game-body').classList.remove('blackout-glitch');
            document.getElementById('curse-overlay').style.display = 'none';
            document.getElementById('chaser-speech-overlay').style.display = 'none';

            document.getElementById('jumpscare-overlay').style.display = 'flex';
            playJumpscareScream(); 

            setTimeout(() => {
                document.getElementById('jumpscare-overlay').style.display = 'none';
                document.getElementById('msg').innerHTML = `<span style="color:#ff0033; font-size:36px; text-shadow:0 0 15px #ff0000;">👻 心臓麻痺 👻</span><br><br>あの顔に完全に追いつかれた……。<br>BGMのテンポと狂気度合いは、あいつとの距離そのものだ。音が早くなったら即座に走れ！`;
                document.getElementById('action-btn').innerText = "もう一度潜入する";
                hasDiary = false; buildMazeObjects(); resetPlayer(); initChaserPosition();
                document.getElementById('screen-overlay').style.display = 'flex';
            }, 1200); 
        }

        document.getElementById('start-btn').addEventListener('click', () => {
            initAudio(); document.getElementById('start-screen').style.display = 'none';
            gameActive = true; isDead = false; resetPlayer(); initChaserPosition(); document.body.requestPointerLock();
        });

        document.getElementById('action-btn').addEventListener('click', () => {
            initAudio(); document.getElementById('screen-overlay').style.display = 'none';
            gameActive = true; isDead = false; resetPlayer(); initChaserPosition(); document.body.requestPointerLock();
        });

        buildMazeObjects();

        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            const time = clock.getElapsedTime();
            const deltaTime = Math.min(0.1, clock.getDelta()); 

            if (gameActive && !isDead) {
                updateEnvironmentLights(time, deltaTime);
                updatePlayerMovement(time);
                updateChaserAI(time);
                checkItemCollisions();
            }

            if (gameActive && !isDead) {
                generateFaceTexture(time);
                chaserTexture.needsUpdate = true;
                drawHorrorFaceToCtx(gCtx, 600, 600, time);
            }
            
            if (isDead && document.getElementById('jumpscare-overlay').style.display === 'flex') {
                drawHorrorFaceToCtx(jsCtx, 600, 600, time);
            }

            if (gameActive) drawMinimap(time);

            if (!hasDiary) {
                diaryMesh.rotation.y += 0.02;
                diaryMesh.position.y = 0.3 + Math.sin(time * 3) * 0.06;
            }
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
