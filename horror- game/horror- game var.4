        const floorConfigs = {
            1: { startGrid: {x: 1, z: 13}, diaryGrid: {x: 12, z: 1} },
            2: { startGrid: {x: 1, z: 15}, diaryGrid: {x: 15, z: 1} },
            3: { startGrid: {x: 1, z: 19}, diaryGrid: {x: 19, z: 1} }
        };

        const diaryTexts = {
            1: "【田中チー牛１１歳のノート 1ページ目】\n\nここには恐ろしい「棚」や「クローゼット」がある。\nEキーで扉をあけて、スペースキーで中に滑り込めるみたいだ。\nでも気をつけろ。あいつに追われながら隠れたり、中で明かりを点けたままだと、扉の目の前で足を止め、狂ったようにこじ開けてくるんだ……！",
            2: "【田中チー牛１１歳のノート 2ページ目】\n\nあいつは隠れ場所のすぐ近くを通るとき、僕たちの「荒い息づかい」や「ライトの光」にひどく敏感になる。\n隠れる前にダッシュしすぎると息が上がって見つかるリスクが跳ね上がる。\n完全に気配を殺すには、隠れる前に歩き、中でライトを消すしかない……。",
            3: "【ボロボロの引き裂かれた日記】\n\n最下層だ。もう逃げ場はない。\n隠れている時、外は見えない。扉の細い隙間から漏れるわずかな闇の景色と、外から迫る「ガタガタガタ！！」という扉を壊す音だけが鼓膜を突き刺す。\n日記を拾った。スタート地点へ戻らなければ、僕の精神がバラバラに引き裂かれる！"
        };

        const horrorVoices = [
            "見 つ け た よ",
            "そ こ に い た ん だ ね",
            "ど こ へ 逃 ゲる の ？",
            "ね ぇ 、 開 け て ？？"
        ];

        let currentFloor = 1;
        let mapData = mazes[currentFloor];
        let config = floorConfigs[currentFloor];

        let gameActive = false;
        let hasDiary = false;
        let isDead = false;

        let stamina = 100;
        let isSprinting = false;
        let staminaExhausted = false;

        let isJumping = false;
        let velocityY = 0;
        const GRAVITY = -0.012; 
        const JUMP_FORCE = 0.2;
        const PLAYER_HEIGHT = 1.35; // 視点を少し低くして這いよる恐怖感を向上

        let isFlashlightOn = true;

        let flashlightMalfunctionTimer = 0;
        let isFlashlightMalfunctioning = false;
        let nextMalfunctionTime = 12.0; 

        let blackoutCycleTimer = 0; 
        let isBlackout = false;
        let hasPlayedWarningSound = false;

        let minimapGlobalTimer = 0;

        let isHiding = false;
        let activeHidingPlace = null; 
        let hidingSpotted = false;    
        let hidingPlacesInScene = []; 

        let chaserBreakInTimer = 0;
        let isChaserBreakingIn = false;

        let chaserTargetNode = { x: 0, z: 0 }; 
        let isChaserChasing = false;          

        const BASE_PLAYER_SPEED = 0.055; 
        const SPRINT_PLAYER_SPEED = 0.11; 
        let chaserSpeed = 0.026;         

        let audioCtx = null;
        let masterGain = null;
        let nextHeartbeatTime = 0;
        let nextChaserFootTime = 0;
        let nextPlayerFootTime = 0; 
        let nextBgmStepTime = 0; 
        let nextKnockSoundTime = 0;

        let chaserPos = { x: 0, z: 0 };
        let playerPos = { x: 0, z: 0, y: PLAYER_HEIGHT };
        const keys = {};

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                masterGain = audioCtx.createGain();
                masterGain.gain.setValueAtTime(3.5, audioCtx.currentTime); 
                masterGain.connect(audioCtx.destination);
            }
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }

        function playDynamicBgmStep(dist, isSighted) {
            if (!audioCtx || !gameActive || isDead || !masterGain) return;
            let severity = Math.max(0, Math.min(1.0, 1.0 - (dist / (SCALE * 6.5))));
            let osc = audioCtx.createOscillator();
            let gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(masterGain);
            osc.type = 'triangle';
            let baseFreq = 48 + (severity * 28);
            if (severity > 0.5) baseFreq += (Math.random() > 0.5 ? 3.0 : -3.0); 
            osc.frequency.setValueAtTime(baseFreq, audioCtx.currentTime);
            osc.frequency.linearRampToValueAtTime(32, audioCtx.currentTime + 0.3);
            let vol = 0.25 + (severity * 0.65);
            gain.gain.setValueAtTime(vol, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.32);
            osc.start(); osc.stop(audioCtx.currentTime + 0.35);

            if (isSighted && !isBlackout && severity > 0.1) {
                let highOsc = audioCtx.createOscillator();
                let highGain = audioCtx.createGain();
                highOsc.connect(highGain); highGain.connect(masterGain);
                highOsc.type = 'sine';
                highOsc.frequency.setValueAtTime(2300 + Math.sin(audioCtx.currentTime * 60) * 120, audioCtx.currentTime);
                highGain.gain.setValueAtTime(0.08 * severity, audioCtx.currentTime);
                highGain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.22);
                highOsc.start(); highOsc.stop(audioCtx.currentTime + 0.25);
            }
        }

        function playPlayerFootstep(isRunning, volumeFactor = 1.0) {
            if (!audioCtx || isBlackout || !masterGain) return;
            let osc = audioCtx.createOscillator();
            let gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(masterGain);
            osc.frequency.setValueAtTime(isRunning ? 115 : 90, audioCtx.currentTime);
            osc.frequency.linearRampToValueAtTime(30, audioCtx.currentTime + 0.09);
            gain.gain.setValueAtTime((isRunning ? 0.22 : 0.14) * volumeFactor, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.09);
            osc.start(); osc.stop(audioCtx.currentTime + 0.1);
        }

