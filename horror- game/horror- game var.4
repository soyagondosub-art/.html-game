        // アップロード画像を100%コードでシミュレートして描画するロジック
        function generateFaceTexture(time) {
            fCtx.clearRect(0, 0, 512, 512);
            let w = 512; let h = 512;
            
            // 背景の完全な暗闇
            fCtx.fillStyle = '#000000'; fCtx.fillRect(0, 0, w, h);
            
            // 揺らぎ・バグ用ノイズ
            let jtX = Math.sin(time * 12) * 2;
            let jtY = Math.cos(time * 10) * 2;

            // ① 白い縦長の不気味な顔の輪郭
            fCtx.fillStyle = '#f5f5f5';
            fCtx.beginPath();
            fCtx.ellipse(w/2 + jtX, h/2 - 20 + jtY, 120, 210, 0, 0, Math.PI * 2);
            fCtx.fill();

            // 輪郭に不気味な陰影のグラデーションを追加
            let grad = fCtx.createRadialGradient(w/2, h/2 - 20, 30, w/2, h/2 - 20, 210);
            grad.addColorStop(0, 'rgba(255,255,255,0)');
            grad.addColorStop(0.7, 'rgba(150,150,150,0.2)');
            grad.addColorStop(1, 'rgba(0,0,0,0.85)');
            fCtx.fillStyle = grad;
            fCtx.beginPath(); fCtx.ellipse(w/2 + jtX, h/2 - 20 + jtY, 120, 210, 0, 0, Math.PI * 2); fCtx.fill();

            // 額に垂れ下がる無数の髪の毛（影効果）
            fCtx.fillStyle = '#000000';
            for (let i = 0; i < 25; i++) {
                let hX = w/2 - 120 + i * 10 + Math.sin(time * 3 + i) * 2;
                fCtx.beginPath();
                fCtx.moveTo(hX, h/2 - 230);
                fCtx.lineTo(hX + 6, h/2 - 130 + Math.cos(i) * 30);
                fCtx.lineTo(hX + 12, h/2 - 230);
                fCtx.fill();
            }

            // ② 真っ黒な底なしの眼窩
            let eyeY = h/2 - 60;
            fCtx.fillStyle = '#000000';
            // 左眼
            fCtx.beginPath(); fCtx.ellipse(w/2 - 50 + jtX, eyeY + jtY, 28, 22, 0, 0, Math.PI * 2); fCtx.fill();
            // 右眼
            fCtx.beginPath(); fCtx.ellipse(w/2 + 50 + jtX, eyeY + jtY, 28, 22, 0, 0, Math.PI * 2); fCtx.fill();

            // 目の周りにじっとりと滲む赤い爛れ・血の輪郭
            fCtx.strokeStyle = 'rgba(200, 10, 10, 0.7)'; fCtx.lineWidth = 4;
            fCtx.beginPath(); fCtx.ellipse(w/2 - 50 + jtX, eyeY + jtY, 29, 23, 0, 0, Math.PI * 2); fCtx.stroke();
            fCtx.beginPath(); fCtx.ellipse(w/2 + 50 + jtX, eyeY + jtY, 29, 23, 0, 0, Math.PI * 2); fCtx.stroke();

            // ③ 横に大きく裂けた、血まみれの口元
            let mouthY = h/2 + 70;
            fCtx.fillStyle = '#050000';
            fCtx.beginPath();
            fCtx.ellipse(w/2 + jtX, mouthY + jtY, 95, 55, 0, 0, Math.PI * 2);
            fCtx.fill();
            fCtx.strokeStyle = '#000000'; fCtx.lineWidth = 6; fCtx.stroke();

            // 口を囲むおどろおどろしい血の滲み
            let mGrad = fCtx.createRadialGradient(w/2, mouthY, 40, w/2, mouthY, 95);
            mGrad.addColorStop(0, 'rgba(0,0,0,0)');
            mGrad.addColorStop(0.8, 'rgba(139,0,0,0.6)');
            mGrad.addColorStop(1, 'rgba(0,0,0,0.9)');
            fCtx.fillStyle = mGrad; fCtx.beginPath(); fCtx.ellipse(w/2 + jtX, mouthY + jtY, 95, 55, 0, 0, Math.PI * 2); fCtx.fill();

            // ④ 剥き出しの不揃いな歯
            fCtx.fillStyle = '#e8e8e8'; // 汚れた歯の色
            let totalTeeth = 13;
            for(let i=0; i<totalTeeth; i++) {
                let tX = w/2 - 80 + i * 12.5 + jtX;
                // 上の歯
                fCtx.beginPath();
                fCtx.moveTo(tX, mouthY - 35); fCtx.lineTo(tX + 4, mouthY - 5); fCtx.lineTo(tX + 9, mouthY - 35);
                fCtx.fill();
                // 下の歯
                fCtx.beginPath();
                fCtx.moveTo(tX, mouthY + 35); fCtx.lineTo(tX + 4, mouthY + 5); fCtx.lineTo(tX + 9, mouthY + 35);
