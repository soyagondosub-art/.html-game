        function buildMazeObjects() {
            mazeObjects.forEach(obj => scene.remove(obj));
            mazeObjects = [];
            hidingPlacesInScene = [];

            let R = mapData.length;
            let C = mapData[0].length;

            for (let r = 0; r < R; r++) {
                for (let c = 0; c < C; c++) {
                    let val = mapData[r][c];
                    let x = c * SCALE;
                    let z = r * SCALE;

                    let fMesh = new THREE.Mesh(floorGeo, floorMat);
                    fMesh.rotation.x = -Math.PI / 2;
                    fMesh.position.set(x, 0, z);
                    fMesh.receiveShadow = true;
                    scene.add(fMesh);
                    mazeObjects.push(fMesh);

                    let cMesh = new THREE.Mesh(floorGeo, ceilMat);
                    cMesh.rotation.x = Math.PI / 2;
                    cMesh.position.set(x, SCALE, z);
                    cMesh.receiveShadow = true;
                    scene.add(cMesh);
                    mazeObjects.push(cMesh);

                    if (val === 1) {
                        let wMesh = new THREE.Mesh(wallGeo, wallMat);
                        wMesh.position.set(x, SCALE / 2, z);
                        wMesh.castShadow = true;
                        wMesh.receiveShadow = true;
                        scene.add(wMesh);
                        mazeObjects.push(wMesh);
                    }
                    else if (val === 2) {
                        createHidingPlaceMesh(x, z, 'shelf', 0x553b1e);
                    }
                    else if (val === 3) {
                        createHidingPlaceMesh(x, z, 'closet', 0x242424);
                    }
                }
            }

            let sX = config.startGrid.x * SCALE;
            let sZ = config.startGrid.z * SCALE;
            const startGeo = new THREE.PlaneGeometry(SCALE * 0.9, SCALE * 0.9);
            const startMat = new THREE.MeshBasicMaterial({ color: 0x00ff00, wireframe: true, side: THREE.DoubleSide });
            startZoneMesh = new THREE.Mesh(startGeo, startMat);
            startZoneMesh.rotation.x = -Math.PI / 2;
            startZoneMesh.position.set(sX, 0.01, sZ);
            scene.add(startZoneMesh);
            mazeObjects.push(startZoneMesh);

            let dX = config.diaryGrid.x * SCALE;
            let dZ = config.diaryGrid.z * SCALE;
            const diaryGeo = new THREE.BoxGeometry(0.35, 0.06, 0.45);
            const diaryMat = new THREE.MeshStandardMaterial({ color: 0xffaa00, emissive: 0x442200, roughness: 0.5 });
            diaryMesh = new THREE.Mesh(diaryGeo, diaryMat);
            diaryMesh.position.set(dX, 0.3, dZ);
            diaryMesh.castShadow = true;
            scene.add(diaryMesh);
            mazeObjects.push(diaryMesh);
        }

        function createHidingPlaceMesh(x, z, type, colorHex) {
            let group = new THREE.Group();
            group.position.set(x, 0, z);

            let mainMat = new THREE.MeshStandardMaterial({ color: colorHex, roughness: 0.8 });
            let geo, mesh;

            if (type === 'shelf') {
                geo = new THREE.BoxGeometry(1.6, 2.0, 0.7);
                mesh = new THREE.Mesh(geo, mainMat);
                mesh.position.y = 1.0;
                group.add(mesh);
            } else if (type === 'closet') {
                geo = new THREE.BoxGeometry(1.4, 2.2, 1.1);
                mesh = new THREE.Mesh(geo, mainMat);
                mesh.position.y = 1.1;
                group.add(mesh);
            }

            mesh.castShadow = true;
            mesh.receiveShadow = true;

            scene.add(group);
            mazeObjects.push(group);

            hidingPlacesInScene.push({ x: x, z: z, type: type, mesh: group, isOpen: false });
        }

        function initPlayerAndChaserPositions() {
            playerPos.x = config.startGrid.x * SCALE;
            playerPos.z = config.startGrid.z * SCALE;
            playerPos.y = PLAYER_HEIGHT;
            yaw = 0; pitch = 0;
            camera.rotation.set(0,0,0);

            let R = mapData.length;
            let C = mapData[0].length;
            let ok = false;
            for(let r=1; r<R-1; r++){
                for(let c=1; c<C-1; c++){
                    if(mapData[r][c] === 0 && (Math.abs(c - config.startGrid.x) > 4 || Math.abs(r - config.startGrid.z) > 4)){
                        chaserPos.x = c * SCALE;
                        chaserPos.z = r * SCALE;
                        chaserTargetNode.x = c;
                        chaserTargetNode.z = r;
                        ok = true; break;
                    }
                }
                if(ok) break;
            }
            if(!ok) {
                chaserPos.x = config.diaryGrid.x * SCALE;
                chaserPos.z = config.diaryGrid.z * SCALE;
                chaserTargetNode.x = config.diaryGrid.x;
                chaserTargetNode.z = config.diaryGrid.z;
            }
            chaserMesh.position.set(chaserPos.x, 1.1, chaserPos.z);
            isChaserChasing = false;
            isChaserBreakingIn = false;
            chaserBreakInTimer = 0;

            flashlightMalfunctionTimer = 0;
            isFlashlightMalfunctioning = false;
            nextMalfunctionTime = 10.0 + Math.random() * 15.0; 
        }

        function updateEnvironmentLights(time, deltaTime) {
            blackoutCycleTimer += deltaTime;
            
            // 懐中電灯の強制消灯バグ（不具合システム）
            if (!isBlackout) {
                flashlightMalfunctionTimer += deltaTime;
                if (!isFlashlightMalfunctioning && flashlightMalfunctionTimer >= nextMalfunctionTime) {
                    isFlashlightMalfunctioning = true;
                    flashlightMalfunctionTimer = 0;
                    playSwitchSound(); 
                    setTimeout(() => { if(audioCtx) playSwitchSound(); }, 150);
                    document.getElementById('guide-notice').innerHTML = `<span style="color:#ff3333;">⚠️ 懐中電灯の接触不良が発生中…！</span>`;
                }
                
                if (isFlashlightMalfunctioning) {
                    if (flashlightMalfunctionTimer > 3.5) { 
                        isFlashlightMalfunctioning = false;
                        flashlightMalfunctionTimer = 0;
                        nextMalfunctionTime = 15.0 + Math.random() * 20.0; 
                        playSwitchSound();
                        document.getElementById('guide-notice').innerHTML = `懐中電灯の出力が安定した。`;
                    }
                }
            }

            if (blackoutCycleTimer < 25.0) {
                isBlackout = false;
                hasPlayedWarningSound = false;
            } else if (blackoutCycleTimer < 28.0) {
                if (!hasPlayedWarningSound) {
                    playSparkSound();
                    hasPlayedWarningSound = true;
                }
                isBlackout = (Math.floor(time * 12) % 2 === 0); 
            } else if (blackoutCycleTimer < 36.0) {
                isBlackout = true;
            } else {
                blackoutCycleTimer = 0;
                isBlackout = false;
                playSparkSound();
            }

            if (isBlackout) {
                ambientLight.intensity = 0.0;
                emergencyLight.intensity = 0.0;
                flashlight.intensity = 0.0;
                document.getElementById('game-body').classList.add('blackout-glitch');
                return;
            }

            document.getElementById('game-body').classList.remove('blackout-glitch');
            ambientLight.intensity = 1.0;
            emergencyLight.intensity = 0.35;

            if (isFlashlightOn && !isHiding && !isFlashlightMalfunctioning) {
                if (isFlashlightMalfunctioning && flashlightMalfunctionTimer > 2.8) {
                    flashlight.intensity = (Math.floor(time * 25) % 2 === 0) ? 25.0 : 0.0;
                } else {
                    flashlight.intensity = 25.0; 
                }
            } else {
                flashlight.intensity = 0.0;
            }

            emergencyLight.position.set(playerPos.x, SCALE - 0.2, playerPos.z);
            flashlight.position.set(camera.position.x, camera.position.y - 0.1, camera.position.z);

            const dir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
            flashlight.target.position.copy(flashlight.position).add(dir);
        }

        function checkCollision(nx, nz) {
            let buffer = 0.38;
            let grids = [
                { r: Math.floor((nz - buffer + SCALE/2) / SCALE), c: Math.floor((nx - buffer + SCALE/2) / SCALE) },
                { r: Math.floor((nz - buffer + SCALE/2) / SCALE), c: Math.floor((nx + buffer + SCALE/2) / SCALE) },
                { r: Math.floor((nz + buffer + SCALE/2) / SCALE), c: Math.floor((nx - buffer + SCALE/2) / SCALE) },
                { r: Math.floor((nz + buffer + SCALE/2) / SCALE), c: Math.floor((nx + buffer + SCALE/2) / SCALE) }
            ];
            for (let g of grids) {
                if (g.r < 0 || g.r >= mapData.length || g.c < 0 || g.c >= mapData[0].length) return true;
                if (mapData[g.r][g.c] === 1) return true; 
            }
            return false;
        }

        function updatePlayerMovement(time) {
            if (isHiding) {
                camera.position.set(playerPos.x, playerPos.y, playerPos.z);
                updateHidingPrompt();
                return;
            }

            isSprinting = (keys['shift'] && stamina > 0 && (keys['w'] || keys['s'] || keys['a'] || keys['d']));
            if (isSprinting) {
                stamina = Math.max(0, stamina - 0.38);
                if (stamina === 0) staminaExhausted = true;
            } else {
                stamina = Math.min(100, stamina + 0.18);
                if (stamina > 20) staminaExhausted = false;
            }
            document.getElementById('stamina-bar').style.width = stamina + '%';
            document.getElementById('stamina-bar').style.background = staminaExhausted ? '#ff3333' : (isSprinting ? '#ffaa00' : '#00ffaa');

            let currentSpeed = isSprinting ? SPRINT_PLAYER_SPEED : BASE_PLAYER_SPEED;
            if (staminaExhausted) currentSpeed = BASE_PLAYER_SPEED * 0.6;

            let moveX = 0;
            let moveZ = 0;

            if (keys['w']) moveZ -= 1;
            if (keys['s']) moveZ += 1;
            if (keys['a']) moveX -= 1;
            if (keys['d']) moveX += 1;

            if (moveX !== 0 || moveZ !== 0) {
                let length = Math.sqrt(moveX * moveX + moveZ * moveZ);
                let frontX = Math.sin(yaw);
                let frontZ = Math.cos(yaw);
                
                let rightX = -Math.sin(yaw - Math.PI / 2);
                let rightZ = -Math.cos(yaw - Math.PI / 2);

                let dx = (moveX * rightX + moveZ * frontX) / length * currentSpeed;
                let dz = (moveX * rightZ + moveZ * frontZ) / length * currentSpeed;

                if (!checkCollision(playerPos.x + dx, playerPos.z)) playerPos.x += dx;
                if (!checkCollision(playerPos.x, playerPos.z + dz)) playerPos.z += dz;

                if (time > nextPlayerFootTime && !isJumping) {
                    playPlayerFootstep(isSprinting);
                    nextPlayerFootTime = time + (isSprinting ? 0.26 : 0.45);
                }
            }

            if (isJumping) {
                playerPos.y += velocityY;
                velocityY += GRAVITY;
                if (playerPos.y <= PLAYER_HEIGHT) {
                    playerPos.y = PLAYER_HEIGHT;
                    isJumping = false;
                    velocityY = 0;
                    playPlayerFootstep(false, 1.4); 
                }
            }

            camera.position.set(playerPos.x, playerPos.y, playerPos.z);
            updateHidingPrompt();
        }

        function updateHidingPrompt() {
            let promptDiv = document.getElementById('hiding-prompt');
            let visionOverlay = document.getElementById('hiding-vision-overlay');

            if (isHiding) {
                promptDiv.style.display = 'block';
                promptDiv.innerHTML = '【Spaceキー】隠れ場所から出る';
                visionOverlay.style.display = 'block'; 
                return;
            }

            visionOverlay.style.display = 'none';
            activeHidingPlace = null;
            let closePlace = null;
            let minDist = 1.6; 

            for (let p of hidingPlacesInScene) {
                let dx = playerPos.x - p.x;
                let dz = playerPos.z - p.z;
                let d = Math.sqrt(dx*dx + dz*dz);
                if (d < minDist) {
                    minDist = d;
                    closePlace = p;
                }
            }

            if (closePlace) {
                activeHidingPlace = closePlace;
                promptDiv.style.display = 'block';
                let typeJa = closePlace.type === 'shelf' ? '棚' : 'クローゼット';
                
                if (!closePlace.isOpen) {
                    promptDiv.innerHTML = `【Eキー】${typeJa}の扉を開ける`;
                } else {
                    promptDiv.innerHTML = `【Spaceキー】${typeJa}の中に隠れる <br> <span style="font-size:12px;color:#ffaa00;">【Eキー】扉を閉める</span>`;
                }
            } else {
                promptDiv.style.display = 'none';
            }
        }

        function toggleDoor() {
            if (isHiding) return;
            if (activeHidingPlace) {
                activeHidingPlace.isOpen = !activeHidingPlace.isOpen;
                playDoorCreakSound();
                
                if (activeHidingPlace.isOpen) {
                    activeHidingPlace.mesh.position.y = 0.25; 
                } else {
                    activeHidingPlace.mesh.position.y = 0.0;
                }
            }
        }

        function toggleHiding() {
            if (isHiding) {
                isHiding = false;
                isChaserBreakingIn = false;
                chaserBreakInTimer = 0;
                let typeJa = activeHidingPlace.type === 'shelf' ? '棚' : 'クローゼット';
                document.getElementById('guide-notice').innerHTML = `【隠蔽解除】${typeJa}から外に出た。`;
                playDoorCreakSound();
                return;
            }

            if (activeHidingPlace && activeHidingPlace.isOpen) {
                isHiding = true;
                activeHidingPlace.isOpen = false;
                activeHidingPlace.mesh.position.y = 0.0;

                hidingSpotted = isChaserChasing; 
                let typeJa = activeHidingPlace.type === 'shelf' ? '棚' : 'クローゼット';
                
                if (hidingSpotted) {
                    document.getElementById('guide-notice').innerHTML = `⚠️ アイツに見られながら${typeJa}に隠れてしまった！`;
                } else {
                    document.getElementById('guide-notice').innerHTML = `【隠蔽中】${typeJa}に潜んだ。気配を殺せ…`;
                }
                playDoorCreakSound();
            }
        }

        function getNeighbors(node) {
            let res = [];
            let dirs = [{x:0, z:1}, {x:0, z:-1}, {x:1, z:0}, {x:-1, z:0}];
            for(let d of dirs){
                let nx = node.x + d.x;
                let nz = node.z + d.z;
                if(nz >= 0 && nz < mapData.length && nx >= 0 && nx < mapData[0].length){
                    if(mapData[nz][nx] !== 1) res.push({x: nx, z: nz});
                }
            }
            return res;
        }

        function findPath(start, target) {
            let queue = [ [start] ];
            let visited = new Set();
            visited.add(`${start.x},${start.z}`);

            while(queue.length > 0){
                let path = queue.shift();
                let curr = path[path.length - 1];

                if(curr.x === target.x && curr.z === target.z) return path;

                for(let n of getNeighbors(curr)){
                    let key = `${n.x},${n.z}`;
                    if(!visited.has(key)){
                        visited.add(key);
                        queue.push([...path, n]);
                    }
                }
            }
            return null; 
        }

        function updateChaserAI(time) {
            let dx = playerPos.x - chaserMesh.position.x;
            let dz = playerPos.z - chaserMesh.position.z;
            let dist = Math.sqrt(dx * dx + dz * dz);

            let pGridX = Math.floor((playerPos.x + SCALE/2) / SCALE);
            let pGridZ = Math.floor((playerPos.z + SCALE/2) / SCALE);
            let cGridX = Math.floor((chaserMesh.position.x + SCALE/2) / SCALE);
            let cGridZ = Math.floor((chaserMesh.position.z + SCALE/2) / SCALE);

            if (isHiding && activeHidingPlace) {
                let hDist = Math.sqrt((activeHidingPlace.x - chaserMesh.position.x) * (activeHidingPlace.x - chaserMesh.position.x) + (activeHidingPlace.z - chaserMesh.position.z) * (activeHidingPlace.z - chaserMesh.position.z));

                let suspicious = hidingSpotted || (hDist < SCALE * 1.5 && (isFlashlightOn || stamina < 85));

                if (suspicious && hDist < SCALE * 1.1) {
                    isChaserBreakingIn = true;
                    chaserMesh.position.set(activeHidingPlace.x, 1.1, activeHidingPlace.z + 0.8); 
                    chaserMesh.lookAt(activeHidingPlace.x, 1.1, activeHidingPlace.z);
                    
                    if (time > nextKnockSoundTime) {
                        playViolentKnockSound();
                        nextKnockSoundTime = time + 0.07;
                        document.getElementById('guide-notice').innerHTML = `<span style="color:red; font-size:16px;">⚠️ ガタガタガタ！！あの白い顔が扉をこじ開けようとしている！！！</span>`;
                    }

                    chaserBreakInTimer += 0.016; 
                    if (chaserBreakInTimer > 3.0) { 
                        triggerJumpscare();
                    }
                    
                    if (time > nextHeartbeatTime) {
                        playHeartbeat(1.0);
                        nextHeartbeatTime = time + 0.25;
                    }
                    return; 
                }
            }

            let canHear = (!isHiding && isSprinting && dist < SCALE * 5.0);
            let hasLineOfSight = false;
            if (dist < SCALE * 4.5 && !isBlackout) {
                hasLineOfSight = true; 
            }

            if ((hasLineOfSight || canHear) && (!isHiding || hidingSpotted)) {
                if(!isChaserChasing) {
                    isChaserChasing = true;
                    triggerSpeechOverlay();
                }
                chaserTargetNode.x = pGridX;
                chaserTargetNode.z = pGridZ;
            } else {
                let curTdx = chaserTargetNode.x * SCALE - chaserMesh.position.x;
                let curTdz = chaserTargetNode.z * SCALE - chaserMesh.position.z;
                if (Math.sqrt(curTdx * curTdx + curTdz * curTdz) < 0.1) {
                    isChaserChasing = false;
                    let R = mapData.length; let C = mapData[0].length;
                    let loopCount = 0;
                    while(loopCount < 40) {
                        let rx = Math.floor(Math.random() * C);
                        let rz = Math.floor(Math.random() * R);
                        if(mapData[rz][rx] !== 1) {
                            chaserTargetNode.x = rx; chaserTargetNode.z = rz; break;
                        }
                        loopCount++;
                    }
                }
            }

            let path = findPath({x: cGridX, z: cGridZ}, chaserTargetNode);
            let nextNode = (path && path.length > 1) ? path[1] : chaserTargetNode;

            let tx = nextNode.x * SCALE;
            let tz = nextNode.z * SCALE;
            let tdx = tx - chaserMesh.position.x;
            let tdz = tz - chaserMesh.position.z;
            let tdist = Math.sqrt(tdx * tdx + tdz * tdz);

            let currentChaserSpeed = isChaserChasing ? chaserSpeed * 1.55 : chaserSpeed;
            if (isBlackout) currentChaserSpeed *= 0.7; 

            if (tdist > 0.02) {
                chaserMesh.position.x += (tdx / tdist) * currentChaserSpeed;
                chaserMesh.position.z += (tdz / tdist) * currentChaserSpeed;
            }

            chaserMesh.position.y = 1.0 + Math.sin(time * 5) * 0.06;
            chaserMesh.lookAt(playerPos.x, chaserMesh.position.y, playerPos.z);

            if (time > nextBgmStepTime) {
                playDynamicBgmStep(dist, isChaserChasing);
                nextBgmStepTime = time + (isChaserChasing ? 0.35 : 0.75);
            }
            if (time > nextHeartbeatTime) {
                let hVol = Math.max(0, Math.min(1.0, 1.0 - (dist / (SCALE * 5.0))));
                if (hVol > 0.02) playHeartbeat(hVol);
                nextHeartbeatTime = time + 0.9 - (hVol * 0.5);
            }
            if (time > nextChaserFootTime && dist < 15.0) {
                let fVol = Math.max(0, Math.min(1.0, 1.0 - (dist / 15.0)));
                playChaserFootstep(fVol);
                nextChaserFootTime = time + (isChaserChasing ? 0.24 : 0.5);
            }

            let alertDiv = document.getElementById('yusei-alert');
            if (dist < SCALE * 3.0) {
                alertDiv.style.display = 'block';
            } else {
                alertDiv.style.display = 'none';
            }

            if (dist < 0.95 && !isHiding) {
                triggerJumpscare();
            }
        }

        function triggerSpeechOverlay() {
            let overlay = document.getElementById('chaser-speech-overlay');
            if (overlay.style.display === 'block') return;
            overlay.innerHTML = horrorVoices[Math.floor(Math.random() * horrorVoices.length)];
            overlay.style.display = 'block';
            setTimeout(() => overlay.style.display = 'none', 1600);
        }

        function checkItemCollisions() {
            if (!hasDiary) {
                let dx = playerPos.x - diaryMesh.position.x;
                let dz = playerPos.z - diaryMesh.position.z;
                if (Math.sqrt(dx*dx + dz*dz) < 1.0) {
                    hasDiary = true;
                    scene.remove(diaryMesh);
                    document.getElementById('diary-content').innerText = diaryTexts[currentFloor];
                    document.getElementById('diary-overlay').style.display = 'flex';
                    document.exitPointerLock();
                }
            } else {
                let sGridX = config.startGrid.x * SCALE;
                let sGridZ = config.startGrid.z * SCALE;
                let dx = playerPos.x - sGridX;
                let dz = playerPos.z - sGridZ;
                if (Math.sqrt(dx*dx + dz*dz) < 1.1) {
                    triggerFloorClear();
                }
            }
        }

        function triggerFloorClear() {
