        function drawMinimap(time) {
            minimapGlobalTimer += 1;
            const canvas = document.getElementById('minimap');
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, 180, 180);

            let R = mapData.length;
            let C = mapData[0].length;
            
            let cellW = 180 / C;
            let cellH = 180 / R;

            ctx.fillStyle = 'rgba(5,7,5,0.9)';
            ctx.fillRect(0,0,180,180);

            for (let r = 0; r < R; r++) {
                for (let c = 0; c < C; c++) {
                    if (mapData[r][c] === 1) {
                        ctx.fillStyle = '#121a16'; 
                        ctx.fillRect(c * cellW, r * cellH, cellW, cellH);
                    }
                }
            }

            for (let p of hidingPlacesInScene) {
                let gridX = Math.floor((p.x + SCALE/2) / SCALE);
                let gridZ = Math.floor((p.z + SCALE/2) / SCALE);
                ctx.fillStyle = '#2255aa'; 
                ctx.fillRect(gridX * cellW + 1, gridZ * cellH + 1, cellW - 2, cellH - 2);
            }

            ctx.strokeStyle = '#00ff00'; ctx.lineWidth = 2.0; 
            ctx.strokeRect(config.startGrid.x * cellW, config.startGrid.z * cellH, cellW, cellH);

            if (!hasDiary) {
                let dX = (config.diaryGrid.x + 0.5) * cellW;
                let dZ = (config.diaryGrid.z + 0.5) * cellH;
                ctx.fillStyle = (Math.floor(time * 4) % 2 === 0) ? '#ffff00' : '#888800';
                ctx.beginPath(); ctx.arc(dX, dZ, cellW * 0.35, 0, Math.PI * 2); ctx.fill();
            }

            let pGridX = (playerPos.x + SCALE/2) / SCALE;
            let pGridZ = (playerPos.z + SCALE/2) / SCALE;
            let px = pGridX * cellW;
            let pz = pGridZ * cellH;

            ctx.save();
            ctx.translate(px, pz);
            ctx.rotate(-yaw); 

            ctx.strokeStyle = 'rgba(255, 255, 255, 0.8)'; ctx.lineWidth = 1.5;
            ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(0, -20); ctx.stroke();

            ctx.fillStyle = '#00ffaa';
            ctx.beginPath(); ctx.moveTo(0, -5); ctx.lineTo(-4, 3); ctx.lineTo(4, 3); ctx.closePath(); ctx.fill();
            ctx.restore();

            let cGridX = (chaserMesh.position.x + SCALE/2) / SCALE;
            let cGridZ = (chaserMesh.position.z + SCALE/2) / SCALE;
            let cx = cGridX * cellW;
            let cz = cGridZ * cellH;

            let dx = playerPos.x - chaserMesh.position.x;
            let dz = playerPos.z - chaserMesh.position.z;
            let dist = Math.sqrt(dx*dx + dz*dz);

            if (dist < SCALE * 4.5 || isChaserChasing) {
                let pulseRad = (minimapGlobalTimer % 35) / 35 * 14 + 3;
                ctx.strokeStyle = 'rgba(255, 0, 0, 0.6)'; ctx.lineWidth = 1.5;
                ctx.beginPath(); ctx.arc(cx, cz, pulseRad, 0, Math.PI * 2); ctx.stroke();
                ctx.fillStyle = '#ff0033';
                ctx.beginPath(); ctx.arc(cx, cz, 4.5, 0, Math.PI * 2); ctx.fill();
            }
        }

        window.addEventListener('keydown', (e) => {
            let k = e.key.toLowerCase();
            keys[k] = true;

            if (k === 'q' && gameActive && !isDead) {
                if (isFlashlightMalfunctioning) {
                    playSwitchSound(); 
                    return;
                }
                isFlashlightOn = !isFlashlightOn;
                playSwitchSound();
                document.getElementById('guide-notice').innerHTML = isFlashlightOn ? '懐中電灯を点灯した。' : '懐中電灯を消灯した。';
            }
            
            if (k === 'e' && gameActive && !isDead) {
                toggleDoor();
            }

            if (e.key === ' ' && gameActive && !isDead) {
                if (activeHidingPlace && activeHidingPlace.isOpen) {
                    toggleHiding();
                } else if (isHiding) {
                    toggleHiding();
                } else {
                    if (!isJumping) {
                        isJumping = true;
                        velocityY = JUMP_FORCE;
                    }
                }
            }
        });
        window.addEventListener('keyup', (e) => {
            if (e.key === ' ') keys[' '] = false;
            else keys[e.key.toLowerCase()] = false;
        });

        window.addEventListener('mousemove', (e) => {
            if (document.pointerLockElement !== container) return;
            let sensitivity = 0.0022;
            yaw -= e.movementX * sensitivity;
            pitch -= e.movementY * sensitivity;
            pitch = Math.max(-Math.PI / 2.8, Math.min(Math.PI / 2.8, pitch));

            camera.rotation.set(pitch, yaw, 0);
        });

        document.getElementById('start-btn').addEventListener('click', () => {
            initAudio();
            document.getElementById('start-screen').style.display = 'none';
            buildMazeObjects();
            initPlayerAndChaserPositions();
            gameActive = true;
            container.requestPointerLock();
        });

        document.getElementById('diary-close-btn').addEventListener('click', () => {
            document.getElementById('diary-overlay').style.display = 'none';
            document.getElementById('guide-notice').innerHTML = `⚠️ 日記を確保した！スタート地点（緑枠）まで走って戻れ！`;
            container.requestPointerLock();
        });

        container.addEventListener('click', () => {
            if (gameActive && !isDead && document.getElementById('diary-overlay').style.display !== 'flex') {
                container.requestPointerLock();
            }
        });

        buildMazeObjects();

        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            const time = clock.getElapsedTime();
            const deltaTime = Math.min(0.1, clock.getDelta()); 

            if (gameActive && !isDead) {
                updateEnvironmentLights(time, deltaTime);
                updatePlayerMovement(time);
                updateChaserAI(time);
                checkItemCollisions();
            }

            if (gameActive && !isDead) {
                generateFaceTexture(time);
                chaserTexture.needsUpdate = true;
            }
            
            if (isDead && document.getElementById('jumpscare-overlay').style.display === 'flex') {
                drawHorrorFaceToCtx(jsCtx, 800, 800, time);
            }

            if (gameActive) drawMinimap(time);

            if (!hasDiary && diaryMesh) {
                diaryMesh.rotation.y += 0.02;
                diaryMesh.position.y = 0.3 + Math.sin(time * 3) * 0.06;
            }
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
