        // プレイヤー捕獲時の「精神崩壊ジャンプスケア」用の超高解像度ホラーアート
        function drawHorrorFaceToCtx(ctx, w, h, time) {
            ctx.clearRect(0, 0, w, h);
            
            // 狂気ノイズ（揺れ幅を極大に）
            let jtX = Math.sin(time * 110) * 12; 
            let jtY = Math.cos(time * 95) * 12;
            
            ctx.fillStyle = '#050000'; ctx.fillRect(0, 0, w, h);
            
            // 背景の血脈ノイズ
            ctx.strokeStyle = 'rgba(180, 0, 0, 0.3)'; ctx.lineWidth = 3;
            for(let i=0; i<12; i++){
                ctx.beginPath(); ctx.moveTo(Math.sin(time + i) * w, 0); ctx.lineTo(w/2 + jtX, h/2 + jtY); ctx.stroke();
            }

            // 死人のような白い輪郭
            ctx.fillStyle = '#e8e8e8'; 
            ctx.beginPath();
            ctx.ellipse(w/2 + jtX, h/2 - 30 + jtY, 180, 310, 0, 0, Math.PI * 2);
            ctx.fill();

            // 輪郭影
            let sGrad = ctx.createRadialGradient(w/2+jtX, h/2-30+jtY, 50, w/2+jtX, h/2-30+jtY, 310);
            sGrad.addColorStop(0, 'transparent');
            sGrad.addColorStop(0.8, 'rgba(100,100,100,0.3)');
            sGrad.addColorStop(1, 'rgba(0,0,0,0.95)');
            ctx.fillStyle = sGrad; ctx.beginPath(); ctx.ellipse(w/2 + jtX, h/2 - 30 + jtY, 180, 310, 0, 0, Math.PI * 2); ctx.fill();

            // 髪の垂れ下がり
            ctx.fillStyle = '#000000';
            for (let i = 0; i < 40; i++) {
                let hX = w/2 - 180 + i * 9 + Math.sin(time * 5 + i) * 4;
                ctx.beginPath(); ctx.moveTo(hX, h/2 - 340); ctx.lineTo(hX + 10, h/2 - 170 + Math.cos(i) * 40); ctx.lineTo(hX + 18, h/2 - 340); ctx.fill();
            }

            // 虚無の眼窩
            let eyeY = h/2 - 90;
            ctx.fillStyle = '#000000';
            ctx.beginPath(); ctx.ellipse(w/2 - 75 + jtX, eyeY + jtY, 44, 34, 0, 0, Math.PI * 2); ctx.fill();
            ctx.beginPath(); ctx.ellipse(w/2 + 75 + jtX, eyeY + jtY, 44, 34, 0, 0, Math.PI * 2); ctx.fill();

            // 眼窩の周囲の爛れ
            ctx.strokeStyle = 'rgba(230, 0, 0, 0.9)'; ctx.lineWidth = 6;
            ctx.beginPath(); ctx.ellipse(w/2 - 75 + jtX, eyeY + jtY, 46, 36, 0, 0, Math.PI * 2); ctx.stroke();
            ctx.beginPath(); ctx.ellipse(w/2 + 75 + jtX, eyeY + jtY, 46, 36, 0, 0, Math.PI * 2); ctx.stroke();

            // 裂けた巨大な口
            let mouthY = h/2 + 100;
            ctx.fillStyle = '#020000';
            ctx.beginPath(); ctx.ellipse(w/2 + jtX, mouthY + jtY, 140, 85, 0, 0, Math.PI * 2); ctx.fill();

            let mGrad = ctx.createRadialGradient(w/2+jtX, mouthY+jtY, 30, w/2+jtX, mouthY+jtY, 140);
            mGrad.addColorStop(0, 'transparent');
            mGrad.addColorStop(0.7, 'rgba(150,0,0,0.7)');
            mGrad.addColorStop(1, 'rgba(0,0,0,1)');
            ctx.fillStyle = mGrad; ctx.beginPath(); ctx.ellipse(w/2 + jtX, mouthY + jtY, 140, 85, 0, 0, Math.PI * 2); ctx.fill();

            // むき出しの不揃いな歯並び
            ctx.fillStyle = '#f0ebd1';
            let tCount = 18;
            for (let i = 0; i < tCount; i++) {
                let tX = w/2 - 120 + i * 13.5 + jtX;
                // 上の鋭い歯
                ctx.beginPath(); ctx.moveTo(tX, mouthY - 55); ctx.lineTo(tX + 5, mouthY - 8); ctx.lineTo(tX + 11, mouthY - 55); ctx.fill();
                // 下の鋭い歯
                ctx.beginPath(); ctx.moveTo(tX, mouthY + 55); ctx.lineTo(tX + 5, mouthY + 8); ctx.lineTo(tX + 11, mouthY + 55); ctx.fill();
            }

            // 歯茎の血の隙間
            ctx.fillStyle = '#5c0101';
            for(let i=0; i<tCount - 1; i++) {
                let tX = w/2 - 110 + i * 13.5 + jtX;
                ctx.fillRect(tX, mouthY - 55, 3, 30);
                ctx.fillRect(tX, mouthY + 25, 3, 30);
            }
        }

